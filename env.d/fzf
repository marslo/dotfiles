# get dynamic prompt from bind -v
__get_fzf_dynamic_prompt() {
  local cgray="\033[38;5;240;1m"
  local creset="\033[0m"

  if [[ "${PROMPT_MODE}" == "simple" ]]; then
    printf "${cgray}%s${creset}" '╰╶ $ '
    return
  fi

  # get current keymap, with fallback to "emacs" if not found
  local keymap=$(bind -v | command grep --color=never "keymap" | awk '{print $3}')
  local mode="emacs-mode-string"
  case "${keymap}" in
    vi-insert       ) mode="vi-ins-mode-string" ;;
    vi-command | vi ) mode="vi-cmd-mode-string" ;;
  esac

  # extract and clean, and handle \033 directly to avoid quote hell
  local raw
  raw=$(bind -v | command grep --color=never "${mode}" | sed "s/^set ${mode} //" | tr -d '\001\002')
  raw="${raw%\"}"
  raw="${raw#\"}"

  # escape sequences: handle \e and remove cursor sequences like \x1b[0 q
  local cleaned="${raw//\\e/$'\e'}"
  cleaned=$(echo -ne "$cleaned" | sed -E 's/\x1b\[[0-9] q//g')

  # return: icon + gray $
  printf "%b${cgray}$ ${creset}" "$cleaned"
}

# hook functions for ctrl-r and ctrl-t
__fzf_ctrl_r_dynamic() {
  local currentPrompt=$(__get_fzf_dynamic_prompt)
  FZF_CTRL_R_OPTS="${FZF_CTRL_R_OPTS} --info=hidden --info-command='' --prompt='${currentPrompt}'" __fzf_history__
}

__fzf_ctrl_t_dynamic() {
  local currentPrompt=$(__get_fzf_dynamic_prompt)
  local selected=$(FZF_CTRL_T_OPTS="${FZF_CTRL_T_OPTS} --info=hidden --info-command='' --prompt='${currentPrompt}'" __fzf_select__)

  if [[ -n "$selected" ]]; then
    READLINE_LINE="${READLINE_LINE:0:$READLINE_POINT}${selected}${READLINE_LINE:$READLINE_POINT}"
    READLINE_POINT=$(( READLINE_POINT + ${#selected} ))
  fi
}

# load fzf bindings first
if test -f "$HOME"/.fzf.bash; then
  source "${ENV_HOME}"/fzf.bash
else
  # test -f "${FZF_HOME}/shell/key-bindings.bash" && source "${FZF_HOME}/shell/key-bindings.bash"
  type -P fzf >/dev/null && eval "$(fzf --bash)"
fi

# custom dynamic prompt and bindings for ctrl-r and ctrl-t
if type __fzf_history__ >/dev/null 2>&1; then
  for km in emacs vi-insert vi-command vi; do
    # unbind
    bind -m ${km} -r "\C-r"
    bind -m ${km} -r "\C-t"

    # re-binding to dynamic hook functions
    bind -m ${km} -x '"\C-r": __fzf_ctrl_r_dynamic'
    bind -m ${km} -x '"\C-t": __fzf_ctrl_t_dynamic'
  done
fi

## preview contents via `$ cd **<tab>` | `$ cd ,,<tab>`: -> FZF_COMPLETION_TRIGGER
# - https://pragmaticpineapple.com/four-useful-fzf-tricks-for-your-terminal/
# - https://github.com/junegunn/fzf?tab=readme-ov-file#fuzzy-completion-for-bash-and-zsh
_fzf_comprun() {
  local command=$1; shift

  case "${command}" in
              tree ) fd . --type d --hidden --follow | fzf --height 60% --preview 'tree -C {}' "$@" ;;
                cd ) fzf --height 60% --preview 'tree -C {} | head -200' "$@" ;;
    export | unset ) fzf --height 60% --preview "eval 'echo \$'{}"       "$@" ;;
                 * ) fzf                                                 "$@" ;;
  esac
}

_fzf_compgen_path() {
  fd --hidden --follow --exclude ".git" --exclude "node_modules" . "$1"
}

_fzf_compgen_dir() {
  fd --type d --hidden --follow --exclude ".git" --exclude "node_modules" . "$1"
}

# usage: _fzf_fill "${cmd}" - similar to `Ctrl+R` in bash
# i.e.:  _fzf_fill seq 10
_fzf_fill() {
  local cmd

  if [[ $# -gt 1 ]] || type "$1" &>/dev/null; then
    cmd=$("$@" | fzf --height 40% --reverse)
  else
    cmd="$*"
  fi

  [ -z "${cmd}" ] && return

  # check count of '\n' in PS1
  # _rows = number of '\n' + 1 (current input line)
  local n_count
  n_count=$(echo -n "$PS1" | grep -o "\\\\n" | wc -l)
  local _rows=$(( n_count + 1 ))

  # cleanup cursor: move up `_rows` lines, clear to the end of line, and return cursor to the beginning of line
  tput cuu "${_rows}"
  tput ed
  tput cr

  # render PS1 with prompt expansion and handle escape sequences properly
  local _prompt=$(echo -ne "${PS1@P}")
  read -re -p "${_prompt}" -i "${cmd}" hisCmd

  # to remove the original command from history - 毁尸灭迹
  # history -d $((HISTCMD)) 2>/dev/null
  if [[ -n "${hisCmd}" ]]; then
    history -a
    eval "${hisCmd}"
    # adding timestamp if HISTTIMEFORMAT is set, to keep consistent with the format in HISTFILE
    {
      [[ -n "$HISTTIMEFORMAT" ]] && echo "#$(date +%s)"
      echo "${hisCmd}"
    } >> "${HISTFILE:-$HOME/.bash_history}"
    # read all history
    history -n
  fi
}

