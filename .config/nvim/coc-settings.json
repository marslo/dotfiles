{
  //  "suppress the python not valid/found issue when open nvim",
  "snippets.ultisnips.pythonPrompt": false,
  "snippets.userSnippetsDirectory": "~/.marslo/vimrc.d/snips",
  "codeLens.enable": true,
  "groovy.enable": true,
  //: "$ sudo ln -sfn $(brew --prefix openjdk)/libexec/openjdk.jdk /Library/Java/JavaVirtualMachines/openjdk.jdk",
  // "groovy.java.home": "/Library/Java/JavaVirtualMachines/openjdk.jdk/Contents/Home",
  "groovy.java.home": "/opt/homebrew/Cellar/openjdk@21/21.0.11/libexec/openjdk.jdk/Contents/Home",
  "groovy.project.referencedLibraries": [
    "/opt/groovy/global-libs/groovy/*",
    "/opt/groovy/global-libs/jenkins/*",
    "/opt/homebrew/opt/groovy/libexec/lib/*",
    "/Users/marslo/.groovy/lib/*",
    "/opt/jenkins/latest/WEB-INF/lib/*",
    "/opt/jenkins/plugins/*/latest/WEB-INF/lib/*"
  ],
  "groovy.ls.vmargs": "-noverify -Xmx2G -XX:+UseG1GC -XX:+UseStringDeduplication",
  // "verbose" / "message" / "off"
  "groovy.trace.server": "off",
  "groovy.ls.feature.noRoot": true,
  "java.referencesCodeLens.enabled": true,
  "java.implementationsCodeLens.enabled": true,
  "java.signatureHelp.enabled": true,

  // java & gradle compatibility
  "java.import.gradle.enabled": true,
  "java.import.gradle.home": "/opt/homebrew/opt/gradle",
  "java.import.gradle.wrapper.enabled": false,
  "java.imports.gradle.wrapper.checksums": [
    {
      "sha256": "af4ff7fffa2c25ebe61221050cc27f5482b14960f3b049f9abe5cadbf0b08085",
      "allowed": true
    },
    {
      "sha256": "7d3a4ac4de1c32b59bc6a4eb8ecb8e612ccd0cf1ae1e99f66902da64df296172",
      "allowed": true
    }
  ],
  "java.compile.nullAnalysis.mode": "automatic",
  // "java.project.importHint": false,
  // "java.autobuild.enabled": false,

  "diagnostic.locationlistUpdate": false,
  // don't display coc diagnostics by ale
  "diagnostic.displayByAle": false,
  "diagnostic.errorSign": "✘",
  "diagnostic.infoSign": "ϊ",
  "diagnostic.warningSign": "",
  "diagnostic.hintSign": "󰷞",
  "diagnostic.virtualText": true,
  "diagnostic.virtualTextCurrentLineOnly": false,
  "diagnostic.checkCurrentLine": false,
  "diagnostic.refreshOnInsertMode": false,
  "diagnostic-languageserver.mergeConfig": true,
   // for : workspace.showOutput → diagnostic-languageserver == groovy.trace.server
  "diagnostic-languageserver.trace.server": "messages",
  "diagnostic-languageserver.linters": {
    "npm-groovy-lint": {
      "command": "/Users/marslo/.npm/bin/npm-groovy-lint",
      "args": [
        "--noserver",
        "--failon",
        "none",
        "--loglevel",
        "warning",
        "-c",
        "/Users/marslo/.groovylintrc.json",
        "-o",
        "json",
        "%filepath"
      ],
      "debounce": 500,
      "sourceName": "npm-groovy-lint",
      "isStdout": true,
      "isStderr": false,
      "parseJson": {
        // lodash.get: %filepath must match `files` keys in npm-groovy-lint JSON (same as last arg). Unrelated to ALE.
        "errorsRoot": "files[\"%filepath\"].errors",
        "line": "line",
        "column": "range.start.character",
        "endLine": "range.end.line",
        "endColumn": "range.end.character",
        "security": "severity",
        "message": "[${rule}] ${msg} "
      },
      "securities": {
        "error": "error",
        "warning": "warning",
        "info": "info"
      }
    }
  },
  "diagnostic-languageserver.filetypes": {
    "yaml": [ "yamllint" ],
    "vim": "vint",
    "sh": "shellcheck",
    "groovy": "npm-groovy-lint"
  },

  "yaml.schemas": {
    "file:///Users/marslo/.marslo/schemas/pre-commit-config.json": ".pre-commit-config.yaml"
  },

  "json.format.enable": true,
  "json.validate.enable": true,
  "json.trace.server": "off",
  "json.maxItemsComputed": 1000,

  "suggest.maxCompleteItemCount": 16,
  "suggest.enablePreselect": true,
  "suggest.labelMaxLength": 666,
  "suggest.detailField": "preview",
  // global default setup
  "floatFactory.floatConfig": {
    "border": true,
    "rounded": true,
    "winblend": 5
  },
  "suggest.floatConfig": {
    "border": true,
    "rounded": true,
    "highlight": "NormalFloat",
    "borderhighlight": "FloatBorder"
  },
  "suggest.pumFloatConfig": {
    "border": false
  },
  "signature.target": "float",
  "signature.floatConfig": {
    "rounded": true,
    "highlight": "NormalFloat",
    "borderhighlight": "FloatBorder"
  },
  "hover.floatConfig": {
    "rounded": true
  },
  "diagnostic.floatConfig": {
    "border": false,
    "rounded": true,
    "winblend": 20
  },

  "html-css-support.styleSheets": [
      "https://cdn.jsdelivr.net/npm/bootstrap@4.5.3/dist/css/bootstrap.min.css",
      "/style.css",
      "style.css"
  ],
  "html-css-support.enabledLanguages": [ "html", "markdown" ],

  "extensions.updateCheck": "daily",
  // :echo coc_git_status OR :echo get(b:, 'coc_git_status', '')
  "git.enableGutters": true,

  "python.formatting.provider": "black",
  "python.linting.pylintEnabled": true,
  "python.linting.enabled": true,
  "python.analysis.useLibraryCodeForTypes": false,
  "python.analysis.typeCheckingMode": "off",
  "pyright.inlayHints.functionReturnTypes" : true,
  "pyright.inlayHints.variableTypes": false,
  "pyright.inlayHints.parameterTypes": false,

  // :echo b:coc_current_function or :echo CocCurrentFunction()
  "coc.preferences.currentFunctionSymbolAutoUpdate": true,

  "coc.source.file.ignoreHidden": false,
  "coc.source.around.priority": 85,
  "coc.source.file.priority": 80,
  "coc.source.tag.priority": 75,
  "coc.source.tag.shortcut": "Tag",
  "coc.source.emoji.shortcut": "E",
  "coc.source.buffer.priority": 70,
  "coc.source.word.priority": 1,
  "coc.source.dictionary.priority": 1
  // "workspace.ignoredFolders": [ "**/.git/**" ]
}
