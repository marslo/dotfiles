# shellcheck disable=SC2154
declare ENV_HOME="${iRCHOME}/env.d"

test -f "${ENV_HOME}"/exports && source "${ENV_HOME}"/exports
test -f "${ENV_HOME}"/prompt  && source "${ENV_HOME}"/prompt
test -f "${ENV_HOME}"/fzf     && source "${ENV_HOME}"/fzf

