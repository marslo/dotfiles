COL_DEFAULT="\[\033[0;38;5;${fgc}m\]"             # "\[$(tput setaf ${fgc})\]"; $"\e[38;5;${fgc}m";
COL_IF_DEFAULT="\[\033[0\;38\;5\;${fgc}m\]"       # COL_IF_DEFAULT="\[\033[1\;38\;5\;${fgc}m\]"  | COL_IF_DEFAULT="${COL_IF_BD_GREEN}"
