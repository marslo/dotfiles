export PROMPT_MODE="${PROMPT_MODE:-complex}"
if [[ "${PROMPT_MODE}" == "simple" ]]; then
  export INPUTRC="${iRCHOME:-${HOME}/.marslo}/inputrc.d/.simplerc"
else
