fi

# simple / complex: bind -f only these fragments (not ~/.inputrc — avoids resetting \C-r / fzf).
function pstoggle() {
  local _INPUTRC_COMPLEX="${iRCHOME:-${HOME}/.marslo}/inputrc.d/.complex"
  local _INPUTRC_SIMPLE="${iRCHOME:-${HOME}/.marslo}/inputrc.d/.simple"

  if [[ "${PROMPT_MODE}" == "complex" ]]; then
    export PROMPT_MODE="simple"
    export PS2="${COL_DEFAULT}   > ${COL_NONE}"
    [[ -r "${_INPUTRC_SIMPLE}" ]] && bind -f "${_INPUTRC_SIMPLE}"
  else
    export PROMPT_MODE="complex"
    export PS2='\[\e[G\e[K\]       '
    [[ -r "${_INPUTRC_COMPLEX}" ]] && bind -f "${_INPUTRC_COMPLEX}"
  fi
}

function __venv_info() {
  local exit_code=$?
  local format=' [%s]'
  local venv=''
  [[ $# -eq 1 ]] && format="$1"
  [[ -n "${VIRTUAL_ENV:-}" ]] && venv="${VIRTUAL_ENV##*/}"
  if [[ -n "${venv}" ]]; then
    # shellcheck disable=SC2059
    printf -- "${format}" "${venv}"
  fi
  return ${exit_code}
}

_build_prompt() {
  local status=$?

  local PROMPT_START=''
  local PROMPT_NEXT=''
  local PROMPT_END=''

  local VENV_RAW=''
  local PS1_VENV=''
  local GIT_RAW=''
  local PS1_GIT=''
  local PS1_STATUS=''

  # one-arg __git_ps1: pcmode=no → gitstring is printf'd to stdout (see git-prompt.sh).
  # add 127.0.0.1 localhost <HOSTNAME> and ::1 localhost <HOSTNAME> to /etc/hosts for better performance (avoid getent hosts <HOSTNAME>).
  GIT_RAW="$(__git_ps1 '%s' 2>/dev/null || true)"
  [[ -n "${GIT_RAW}"       ]] && PS1_GIT=" - (${COL_BD_GREEN}${GIT_RAW}${COL_NONE}${COL_DEFAULT})"
  [[ -n "${VIRTUAL_ENV:-}" ]] && VENV_RAW="${VIRTUAL_ENV##*/}"
  [[ -n "${VENV_RAW}"      ]] && PS1_VENV=" - (${COL_BD_MAGENTA}${VENV_RAW}${COL_NONE}${COL_DEFAULT})"
  [[ ${status} -eq 0       ]] && PS1_STATUS="${COL_DEFAULT} ->${COL_DEFAULT}" || PS1_STATUS="${COL_RED} ↯${COL_DEFAULT}"

  if [[ "${PROMPT_MODE}" = 'simple' ]]; then
    PROMPT_START="\n${COL_DEFAULT}╭╶ (\u${COL_DEFAULT} ${COL_RED}\W${COL_DEFAULT})"
    PROMPT_NEXT="${PS1_GIT}${PS1_VENV}${PS1_STATUS}"
    PROMPT_END="\n${COL_DEFAULT}╰╶ \$ ${COL_NONE}"
    PS1="${PROMPT_START}${PROMPT_NEXT}${PROMPT_END}"
    export PS2="${COL_DEFAULT}   > ${COL_NONE}"
  else
    # $COLUMNS requires: shopt -s checkwinsize
    local cols="${COLUMNS:-$(tput cols 2>/dev/null || printf '%s' 80)}"
    local HOST_RAW="${HOSTNAME%%.*}"
    local length=$(( 2 + 1 + 1 + ${#USER} + 1 + ${#HOST_RAW} + 1   ))
    [[ -n "${GIT_RAW}"  ]] && length=$(( length + 5 + ${#GIT_RAW}  ))
    [[ -n "${VENV_RAW}" ]] && length=$(( length + 5 + ${#VENV_RAW} ))
    length=$(( length + 3 + 2 ))

    local maxlength=$(( cols - length ))
    local p="${PWD/#$HOME/\~}"
    local smartPath="${p}"
    if (( ${#p} > maxlength )) && (( maxlength > 10 )); then
      smartPath="...${p: -$((maxlength - 3))}"
    fi

    PROMPT_START="\n${COL_DEFAULT}╭╶ (\u@${HOST_RAW} ${COL_RED}${smartPath}${COL_DEFAULT})"
    PROMPT_NEXT="${PS1_GIT}${PS1_VENV}${PS1_STATUS}"
    PROMPT_END="\n${COL_DEFAULT}\$ ${COL_NONE}"
    PS1="${PROMPT_START}${PROMPT_NEXT}${PROMPT_END}"
    export PS2='\[\e[G\e[K\]       '
  fi
}

# PS1
PROMPT_COMMAND=_build_prompt

