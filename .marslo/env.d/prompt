# set -x: wall-clock with milliseconds (EPOCHREALTIME: bash 5.1+; else python3)
function _ps4_ts() {
  local frac hms
  if [[ -n "${EPOCHREALTIME:-}" ]]; then
    printf -v hms '%(%Y-%m-%d %H:%M:%S)T' -1
    frac=${EPOCHREALTIME#*.}
    frac="${frac}000"
    printf '%s.%s' "${hms}" "${frac:0:3}"
  elif command -v python3 &>/dev/null; then
    python3 -c 'import datetime; print(datetime.datetime.now().strftime("%Y-%m-%d %H:%M:%S.%f")[:-3])'
  else
    printf '%(%Y-%m-%d %H:%M:%S)T' -1
  fi
}

