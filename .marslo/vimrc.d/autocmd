  augroup Vimrc
    autocmd!
    function! SafeReloadConfig(filepath) abort
      let l:save_pos = winsaveview()
      execute 'silent redraw!'
      echohl WarningMsg
      echom a:filepath . ' changed! ' . $MYVIMRC . ' Reloading ...'
      echohl None
      let l:cmd = 'silent! source $MYVIMRC | silent! call winrestview(' . string(l:save_pos) . ')'
      call timer_start(150, { -> execute(l:cmd) })
    endfunction

    if IsVim() && fnamemodify(expand('%:p:h'), ':t') ==# 'vimrc.d'
      autocmd! BufWritePost ~/.marslo/vimrc.d/* call SafeReloadConfig(expand('%:p'))
    endif
    " -- disable for pos restoring issue when source vimrc -- "
    " if IsNvim() && !exists('g:vscode') && expand('%:p') =~# '^' . stdpath('config')
