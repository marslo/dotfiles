  " for &buftype in 'help', 'nofile', 'terminal', 'quickfix/locationlist', 'prompt', ...
  function! s:MinimalUI() abort
    if IsVscodeOrCursor() || empty(&buftype) | return | endif
    setlocal nonumber norelativenumber nospell nofoldenable signcolumn=no foldcolumn=0 colorcolumn=
    let b:coc_diagnostic_disable = 1
  endfunction

