  augroup AutoSavePos
    autocmd!
    if v:version > 703
      if ! IsVscodeOrCursor()
        autocmd FocusLost   * if empty(&buftype) | setlocal norelativenumber | endif
        autocmd FocusGained * if empty(&buftype) | setlocal relativenumber   | endif
      endif
      autocmd InsertEnter * if empty(&buftype) | setlocal norelativenumber | endif
      autocmd InsertLeave * if empty(&buftype) | setlocal relativenumber   | endif
      autocmd CmdwinEnter * setlocal norelativenumber
      autocmd CmdwinLeave * setlocal relativenumber
      autocmd CmdwinEnter * let b:ei_save = &eventignore | set eventignore=CursorHold,InsertEnter
      autocmd CmdwinLeave * let &eventignore = b:ei_save
