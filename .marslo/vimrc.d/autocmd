" ALE has no b:ale_lint_on_enter; only g:ale_lint_on_enter registers BufWinEnter
" call ale#Queue manually for groovy buffers (same as LintOnEnter).
function! s:AleLintOnGroovy(bufnr) abort
  if !exists('*ale#Queue')
    return
  endif
  let l:ft = getbufvar( a:bufnr, '&filetype' )
  if index( ['groovy'], l:ft ) < 0
    return
  endif
  call ale#Queue( 0, 'lint_file', a:bufnr )
endfunction

function! s:FindJenkinsfileLintRC() abort
  let l:found = findfile('.groovylintrc-jenkinsfile.json', '.;')
  return fnamemodify(!empty(l:found) ? l:found : '~/.groovylintrc-jenkinsfile.json', ':p')
endfunction

function! SafeRetab()
  if expand('%:e') =~# '^\(ltsv\|config\|diffs\)$' | return | endif

  let l:supported_fts = [ 'sh', 'python', 'groovy', 'lua', 'javascript', 'yaml' ]
  let l:is_supported = index( l:supported_fts, &filetype ) != -1
  let l:should_retab = 0

  if l:is_supported
    setlocal expandtab
    if &expandtab && &modifiable && !&readonly | let l:should_retab = 1 | endif
  else
    if &modifiable && !&readonly | let l:should_retab = 1 |endif
  endif

  if l:should_retab
    if search( '\t', 'nw' ) > 0
      silent! keepjumps retab!
      silent! redraw
      echohl WarningMsg | echo 'Retab executed! (Tabs converted to spaces)' | echohl None
    endif
  endif
endfunction

