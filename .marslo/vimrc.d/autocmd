    " https://github.com/jwhitley/vimrc/blob/master/.vimrc
    " autocmd VimEnter * if exists(":Tabularize") | exe ":AddTabularPattern! bundles /[^ ]\\+\\//l1r0" | endif
    " add for plugin/TabularMaps.vim
    autocmd VimEnter * if exists(":Tabularize") | exe ":AddTabularPattern 1,  /^[^,]*\zs,/r1c1l0" | endif
    autocmd VimEnter * if exists(":Tabularize") | exe ":AddTabularPattern 1=  /^[^=]*\zs="        | endif
    autocmd VimEnter * if exists(":Tabularize") | exe ":AddTabularPattern 1== /^[^=]*\zs=/r1c1l0" | endif
  augroup END

  " different:
  " - ColumnLimit can highlight fg color
  " - ColorColumn only for bg (set colorcolumn=80)
  augroup ColumnLimit
    let s:columnLimit = 80
    let s:pattern     = '\%<' . (s:columnLimit+1) . 'v.\%>' . s:columnLimit . 'v'
    highlight! link ColumnLimit ColorColumn
    autocmd!
    autocmd VimEnter,BufWinEnter,WinEnter *
          \ if empty( &buftype ) && ( !exists( 'w:m1' ) || w:m1 == -1 )
          \ |   let w:m1 = matchadd( 'ColumnLimit', s:pattern, -1 )
          \ | endif
  augroup END

