  augroup DevOps
    autocmd!
    autocmd Filetype           Dockerfile          set filetype=dockerfile  syntax=dockerfile
    autocmd Syntax             json,yaml           if empty(&buftype) | silent! normal zM | endif
    autocmd FileType           markdown            syntax sync fromstart
    autocmd FileType           markdown            noremap <buffer> <F5> :!"/Applications/Google Chrome.app/Contents/MacOS/Google Chrome" %:p "--no-gpu"<CR>
    autocmd BufRead,BufNewFile *.tags,.tags,tags   set filetype=tags
    autocmd BufRead,BufNewFile .*ignore            set filetype=ignore
    " ALE vscodejson is LSP, so it keeping show publishDiagnostics when insert; and g:ale_open_list=1 will non-stop execute lopen/lclose
    autocmd FileType           json,jsonc,markdown
            \  let g:indentLine_setConceal   = 0
            \| let g:vim_json_conceal        = 0
            \| let g:vim_json_syntax_conceal = 0
            \| let b:ale_open_list           = 'on_save'
    " force set jsonc for json with comments: $ npm i -g vscode-langservers-extracted
    autocmd BufNewFile,BufRead *rc*.json,*config*.json,*[Ss]ettings*.json,*.json.current,*keybindings.json
            \,*tsconfig*.json
            \,*eslintrc*.json,*babelrc*.json,*.groovylintrc*.json
            \,*.code-workspace
            \,.vscode/*.json
            \ set filetype=jsonc
    autocmd FileType           markdown,html
            \ let g:AutoPairsCompleteOnlyOnSpace = 1 |
            \ let b:AutoPairs = autopairs#AutoPairsDefine({
            \   '<div>':'</div>', '<font>':'</font>', '<a>':'</a>', '<p>':'</p>',
            \   '<table>':'</table>', '<tbody>':'</tbody>',
            \   '<thread>':'</thread>', '<th>':'</th>', '<td>':'</td>',
            \   '<kbd>':'</kbd>',
            \   '<u>':'</u>'
            \ })
    if index( ['project.config', 'groups'], expand('%:r') ) == -1
      autocmd BufRead,BufNewFile *.config set filetype=gitconfig noexpandtab
    endif

    autocmd! BufReadPost,BufNewFile
            \ */gitconfig.d/*
            \,*/.git/config
            \,.gitconfig
            \,.gitmodules
            \,gitconfig
            \ setfiletype gitconfig
  augroup END

  augroup ShellScript
    autocmd!
    autocmd Syntax       bash                 setlocal filetype=sh
    autocmd FileType     sh,bash,shell        call SafeRetab()
    autocmd BufWritePre  *.sh                 call SafeRetab()
    " automatic redraw for shellcheck
    autocmd BufWritePost *.sh                 if has('syntax') && exists('g:loaded_shellcheck') | silent! redraw! | endif
