  augroup Defaults
    autocmd!
    " for modeline
    autocmd BufReadPost *
            \  if getline(1) =~# 'vim:.*ft=help' && &filetype !=# 'help'
            \|   doautocmd FileType
            \| endif
    " set syntax instead of filetype will avoid lint analysis
    autocmd BufEnter           *                               if empty( &filetype ) && empty( &buftype ) | setlocal syntax=groovy nospell | endif
    " restore cursor position when reopen file
    autocmd BufReadPost        *
            \ if line("'\"") > 1 && line("'\"") <= line("$") && &filetype !~# 'commit' |
            \   execute "normal! g`\"" |
            \ endif
    autocmd Syntax             *                               syn match ExtraWhitespace /\s\+$\| \+\ze\t/
    " disable git blame in diff mode
    autocmd BufReadPost        *                               if &diff | let g:blamer_enabled=0 | endif
    " automatic remove trailing space
    autocmd BufWritePre        *
            \ let s:save_pos = winsaveview() |
            \ silent! %s/\s\+$//e |
            \ silent! %s/\r$//e |
            \ call winrestview(s:save_pos)
