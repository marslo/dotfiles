function! GetPlug()                                                 " GetPlug() inspired by: http://pastebin.com/embed_iframe.php?i=C9fUE0M3
  let pluginHome=$HOME . '/.vim/autoload'
  let pluginFile=pluginHome . '/plug.vim'
  if filereadable( pluginFile )
    echo 'vim-plug has existed at ' . expand( pluginFile )
  else
    echo 'download vim-plug to ' . expand( pluginFile ) . '...'
    echo ''
    if isdirectory( expand(pluginHome) ) == 0
      call mkdir( expand(pluginHome), 'p' )
    endif
    execute 'silent !curl --create-dirs https://github.com/junegunn/vim-plug/raw/master/plug.vim -kfLo "' . expand( pluginFile ) . '"'
  endif
endfunction
command! GetPlug :call GetPlug()

" * and # for search
function! VSetSearch()
  " backup register `s` to temp
  let temp = @s
  " gv: virtual mode selection; "s: register name is `s`; y: yank;
  normal! gv"sy
  let @/ = '\V' . substitute( escape(@s, '\/|'), '\n', '\\n', 'g' )
  " restore register `s` from temp
  let @s = temp
endfunction
xnoremap * :<C-u>call VSetSearch()<CR>/<C-R>=@/<CR><CR>:normal! N<CR>
xnoremap # :<C-u>call VSetSearch()<CR>?<C-R>=@/<CR><CR>:normal! n<CR>
"                                     +----+--+---+
"                                       |   |   + `<CR>` ⩵  Enter
"                                       |   + `@/` ⩵  @/
"                                       + `?<C-R>=` ⩵  ? → Ctrl+R → =
" g* and g# for regex search
function! VSetRegexSearch()
  let temp = @s
  normal! gv"sy
  let @/ = '\v' . substitute( escape(@s, '/'), '\n', '\\n', 'g' )
  let @s = temp
endfunction
xnoremap g* :<C-u>call VSetRegexSearch()<CR>/<C-R>=@/<CR><CR>:normal! N<CR>
xnoremap g# :<C-u>call VSetRegexSearch()<CR>?<C-R>=@/<CR><CR>:normal! n<CR>

" twiddle case : https://vim.fandom.com/wiki/Switching_case_of_characters#Twiddle_case
function! TwiddleCase(str)
  if a:str ==# toupper( a:str )
    let result = tolower( a:str )
  elseif a:str ==# tolower( a:str )
    let result = substitute( a:str,'\(\<\w\+\>\)', '\u\1', 'g' )
  else
    let result = toupper( a:str )
  endif
  return result
endfunction
vnoremap ~ y:call setreg('', TwiddleCase(@"), getregtype(''))<CR>gv""Pgv

function! IgnoreSpells()                                            " ignore CamelCase words when spell checking
  syntax      match   CamelCase /\<[A-Z][a-z]\+[A-Z].\{-}\>/ contains=@NoSpell transparent
  syntax      cluster Spell add=CamelCase
  syntax      match   mixedCase /\<[a-z]\+[A-Z].\{-}\>/      contains=@NoSpell transparent
  syntax      cluster Spell add=mixedCase
  " or syntax match   myExNonWords +\<\p*[^A-Za-z \t]\p*\>+  contains=@NoSpell
  " or syntax match   myExCapitalWords +\<\w*[A-Z]\K*\>\|'s+ contains=@NoSpell
  " syntax    match   Url "\w\+:\/\/[:/?#[\]@!$&'()*+,;=0-9[:lower:][:upper:]_\-.~]\+" contains=@NoSpell containedin=@AllSpell transparent
  " syntax    cluster Spell add=Url
  " syntax    match   UrlNoSpell '\w\+:\/\/[^[:space:]]\+'   contains=@NoSpell transparent
  " syntax    cluster Spell add=UrlNoSpell
endfunction
autocmd BufRead,BufNewFile * :call IgnoreSpells()
autocmd Syntax  * :call IgnoreSpells()
set spellcapcheck=                                                  " ignore capital check

" set spellcamelcase=1
fun! IgnoreCamelCaseSpell()                                         " Ignore CamelCase words when spell checking
  syn match CamelCase /\<[A-Z][a-z]\+[A-Z].\{-}\>/ contains=@NoSpell transparent
  syn match mixedCase /\<[a-z]\+[A-Z].\{-}\>/ contains=@NoSpell transparent
  syn cluster Spell add=CamelCase
  syn cluster Spell add=mixedCase
endfun
autocmd BufRead,BufNewFile * :call IgnoreCamelCaseSpell()
autocmd Syntax *             :call IgnoreCamelCaseSpell()
syn match UrlNoSpell '\w\+:\/\/[^[:space:]]\+' contains=@NoSpell

function! GroovyKeywords() abort
  " remove potential interference from polyglot.
  silent! syn clear groovyDocComment
  " nocolor
  syntax keyword noColor                 git push

  " basic keywords
  syntax keyword groovyJDKMethods        collectEntries collectMany eachWithIndex toString first last tail trim
  syntax keyword groovyKeywords          Object Closure stage
  syntax keyword JenkinsPluginsKeywords  writeCSV withEnv

  " handling common map/list definitions
  syntax keyword groovyCustomTypes       Map List String Object

  let s:common_ctx  = ' containedin=ALLBUT,groovyComment,groovyLineComment,groovyBlockComment,groovyDocComment,groovyString,groovyGString'
  let s:op_patterns = [
        \ '\([?]\=\.\)',
        \ '\(<=>\|==\~\|=\~\|->\|?:\|\.\.<\)',
        \ '\(=\|==\|!=\|>=\|<=\|&&\|||\)',
        \ '\(++\|--\)',
        \ '\(<<<\|>>>\|<<\|>>\)',
        \ '\(+\|-\|%\|&\|\^\)=\=',
        \ '/=',
        \ '\s\zs?\ze\s\|\s\zs:\ze\s'
        \ ]
  for pat in s:op_patterns
    execute 'syntax match groovyOperator "' . pat . '"' . s:common_ctx
  endfor

  let s:core_objects = ['params', 'env', 'currentBuild']
  for obj in s:core_objects
    execute 'syntax match jenkinsfileCoreStepNew "\<' . obj . '\>"' . s:common_ctx
    execute 'syntax match jenkinsfileCoreStepNew "\<' . obj . '\(\([?]\=\.[a-zA-Z0-9_]\+\>\)\(\s*(\)\@!\)\+"' . s:common_ctx
  endfor
  execute 'syntax match groovyCustomKeywords "\<it\>"' . s:common_ctx
  execute 'syntax match groovyCustomKeywords "\<it\(\([?]\=\.[a-zA-Z0-9_]\+\>\)\(\s*(\)\@!\)\+"' . s:common_ctx

  " Strong Match for @Field/@NonCPS annotation in Groovy,  Using `containsexcluded` ensures it isn't accidentally swallowed by other rules.
  syntax match   groovyFieldAnnotation /@\(Field\|NonCPS\)/ display
  " @Library(...) annotation in Jenkinsfile
  syntax match   jenkinsLibraryTarget  /'[^']*'\|"[^"]*"/   contained
  syntax match   jenkinsLibraryKeyword /@Library/           contained
  syntax region  jenkinsLibraryRegion
        \ start=/@Library\s*(/
        \ end=/)/
        \ contains=jenkinsLibraryKeyword,jenkinsLibraryTarget,groovyComment
        \ keepend

  " doc comment region, support /** .. **/ and /** .. */
  syntax region  groovyDocComment start="/\*\*"  end="\s*\*\*/" end="\s*\*/" keepend contains=groovyCommentTitle,@groovyHtml,groovyDocTags,groovyTodo,@Spell
  syntax match   groovyDocTags  contained "@\(description\)\>"

  " force refresh of syntax highlighting
  syntax sync fromstart
endfunction
autocmd Syntax groovy,Jenkinsfile,jenkinsfile call GroovyKeywords()

" redir into new tab: https://vim.fandom.com/wiki/Capture_ex_command_outputhttps://vim.fandom.com/wiki/Capture_ex_command_output
" `gt`, `:tabfirst`, `:tabnext`, `:tablast` ... to switch tabs : https://vim.fandom.com/wiki/Alternative_tab_navigation
function! TabMessage(cmd)
  redir => message
  silent execute a:cmd
  redir END
  if empty( message )
    echoerr 'no output'
  else
    " use `new` instead of `tabnew` below if you prefer split windows instead of tabs
    tabnew
    setlocal buftype=nofile bufhidden=wipe noswapfile nobuflisted nomodified filetype=
    silent put=message
  endif
endfunction
command! -nargs=+ -complete=command TabMessage call TabMessage(<q-args>)

