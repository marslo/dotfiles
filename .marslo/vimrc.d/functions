" `,mm` to toggle mouse on/off
nnoremap <leader>mm :call ToggleMouse()<CR>
function! ToggleMouse()
  " check whether if running in ssh
  let l:is_ssh = exists('$SSH_CONNECTION') || exists('$SSH_TTY') || exists('$SSH_CLIENT')
  let l:env = l:is_ssh ? '[SSH]' : '[LOCAL]'

  if &mouse ==# 'a' || &mouse ==# 'nvi'
    set mouse=
    echohl Red   | echon '🖱️ Mouse disabled ' . l:env | echohl None
  else
    set mouse=nvi
    echohl Green | echon '🖱️ Mouse enabled ' . l:env  | echohl None
  endif
endfunction

" highlight paste in both vim and neovim
nnoremap <silent> p p:call PasteHighlight()<CR>
nnoremap <silent> P P:call PasteHighlight()<CR>
function! PasteHighlight() abort
  let l:start = getpos("'[")
  let l:end   = getpos("']")

  if l:start[1] == 0 || l:end[1] == 0 | return | endif

  let l:start_lnum = l:start[1]
  let l:start_col  = l:start[2]
  let l:end_lnum   = l:end[1]
  let l:end_col    = l:end[2]

  if l:start_lnum == l:end_lnum
    let l:len = l:end_col - l:start_col + 1
    let l:match_id = matchaddpos('PasteHighlight', [[l:start_lnum, l:start_col, l:len]])
    call setpos('.', l:end)
  else
    let l:pattern = '\%'.l:start_lnum.'l\_.*\%'.l:end_lnum.'l'
    let l:match_id = matchadd('PasteHighlight', l:pattern)

    call setpos('.', l:start)
  endif

  call timer_start(150, {-> matchdelete(l:match_id)})
endfunction

" highlight yank in vim only
if !has('nvim')
  function! YankHighlight() abort
    if v:event.operator !=# 'y' || v:event.regname !=# ''
      return
    endif

    let l:lines = v:event.regcontents
    let l:type  = v:event.regtype
    let l:lnum  = line('.')
    let l:col   = col('.')

    if l:type ==# 'v'
      " char mode（i.e.: yi(、yaw）
      let l:text = join(l:lines, "\n")
      let l:pattern = '\%' . l:lnum . 'l\%' . l:col . 'c' .
            \ '\_.\{' . strlen(l:text) . '\}'
    elseif l:type ==# 'V'
      " line more ( i.e.: yy )
      let l:pattern = '\%'.l:lnum.'l\_.*\%'.(l:lnum + len(l:lines) - 1).'l'
    else
      " default fallback: highlight only current line
      let l:pattern = '\%' . l:lnum . 'l'
    endif

    " highlight and clear
    let l:match_id = matchadd('IncSearch', l:pattern)
    call timer_start(150, {-> matchdelete(l:match_id)})
  endfunction

  augroup YankHighlightGroup
    autocmd!
    autocmd TextYankPost * call YankHighlight()
  augroup END
endif

" to addresses a performance bottleneck in the GnuPG SSH-Agent when handling high-concurrency SSH handshake requests
function! PlugUpdateHTTPS()
    let l:old_global = $GIT_CONFIG_GLOBAL
    let l:old_system = $GIT_CONFIG_SYSTEM

    let $GIT_CONFIG_GLOBAL = '/dev/null'
    let $GIT_CONFIG_SYSTEM = '/dev/null'

    PlugUpdate

    let $GIT_CONFIG_GLOBAL = l:old_global
    let $GIT_CONFIG_SYSTEM = l:old_system
endfunction
command! PlugUpdateHTTPS call PlugUpdateHTTPS()

" ,cy: copy lint message on current line to clipboard (for ALE plugin)
function! CopyLintMessage() abort
  let l:buf = bufnr('%')
  let l:line = line('.')
  let l:msgs = []
  for l:item in ale#engine#GetLoclist(l:buf)
    if l:item.lnum == l:line
      call add(l:msgs, l:item.text)
    endif
  endfor
  if empty(l:msgs)
    echo 'No lint message on current line'
    return
  endif
  let l:text = join(l:msgs, "\n")
  call system('pbcopy', l:text)
  echo 'Copied: ' . l:text[:80] . (len(l:text) > 80 ? '...' : '')
endfunction
nnoremap <silent> <Leader>cy :call CopyLintMessage()<CR>

" :Iname [-p] : echo current file path, and copy to clipboard if `-p` is provided
function! s:Iname(args) abort
  let l:path = expand('%:p')
  if a:args =~# '\v-?p'
    call system('pbcopy', l:path)
    echo l:path . '  [copied]'
  else
    echo l:path
  endif
endfunction
command! -nargs=? Iname call s:Iname(<q-args>)

" andymass/vim-matchup - to handle `%` jump between matching quotes and markdown code fences
nmap <silent> % :call <SID>JumpMatchingQuote()<CR>
function! s:JumpMatchingQuote()
  let line = getline('.')
  " markdown code fence: % on a ``` line jumps to matching fence
  if &filetype ==# 'markdown' && line =~# '^\s*```'
    let lnum = line('.')
    let l:cnt = 0
    for i in range(1, lnum)
      if getline(i) =~# '^\s*```'
        let l:cnt += 1
      endif
    endfor
    if l:cnt % 2 == 1
      call search('^\s*```', 'W')
    else
      call search('^\s*```', 'bW')
    endif
    return
  endif

  let c = line[col('.') - 1]
  if index(["'", '"', '`'], c) < 0
    execute "normal \<Plug>(matchup-%)"
    return
  endif

  let lnum = line('.')
  let cnum = col('.')
  let syn_here = synIDattr(synID(lnum, cnum, 1), 'name')

  if empty(syn_here)
    execute "normal \<Plug>(matchup-%)"
    return
  endif

  let syn_before = (cnum > 1) ? synIDattr(synID(lnum, cnum - 1, 1), 'name') : ''
  let at_start = (syn_here !=# syn_before)

  let syn_after = synIDattr(synID(lnum, cnum + 1, 1), 'name')
  let at_end = (syn_here !=# syn_after)

  if at_start && !at_end
    call s:ScanToEdge(lnum, cnum, syn_here, 1)
  elseif at_end
    call s:ScanToEdge(lnum, cnum, syn_here, -1)
  else
    execute "normal \<Plug>(matchup-%)"
  endif
endfunction

function! s:ScanToEdge( lnum, col, syn_name, direction )
  let [l, c] = [a:lnum, a:col]
  let lastline = line('$')
  let max_lines = 200
  let scanned = 0
  while scanned < max_lines
    let next_c = c + a:direction
    let line_len = col([l, '$'])
    if next_c < 1 || next_c >= line_len
      let l += a:direction
      let scanned += 1
      if l < 1 || l > lastline | break | endif
      let next_c = ( a:direction > 0 ) ? 1 : col([ l, '$' ]) - 1
      if next_c < 1 | break | endif
    endif
    let c = next_c
    if synIDattr( synID(l, c, 1), 'name' ) !=# a:syn_name
      let c -= a:direction
      if c < 1
        let l -= a:direction
        let c = col([l, '$']) - 1
      endif
      call cursor(l, c)
      return
    endif
  endwhile
endfunction

" :TSGroovyRebuild → rebuild + re-sign the local groovy tree-sitter parser
function! TSGroovyRebuild() abort
  let l:repo = get(g:, 'groovy_ts_repo', '/opt/groovy/tree-sitter-groovy')
  if !isdirectory(l:repo)
    echohl ErrorMsg | echo 'groovy-ts: repo not found: ' . l:repo | echohl NONE
    return
  endif
  echo 'groovy-ts: building (make nvim-install) ...'
  let l:out = system('make -C ' . shellescape(l:repo) . ' nvim-install 2>&1')
  if v:shell_error != 0
    echohl ErrorMsg | echo "groovy-ts: build failed\n" . l:out | echohl NONE
    return
  endif
  echohl MoreMsg | echo 'groovy-ts: rebuilt + signed (restart nvim for the new parser binary)' | echohl NONE
endfunction
command! TSGroovyRebuild call TSGroovyRebuild()

