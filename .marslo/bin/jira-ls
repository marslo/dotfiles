#!/usr/bin/env bash
# shellcheck source=/dev/null
#=============================================================================
#     FileName : jira-ls
#       Author : marslo
#      Created : 2026-01-21 20:57:09
#   LastChange : 2026-07-14 23:38:02
#=============================================================================

set -euo pipefail

# shellcheck disable=SC2155
declare -r ME="$( basename "${BASH_SOURCE[0]:-$0}" | sed 's/-/ /' )"
# shellcheck disable=SC2155
declare -r HERE="$( dirname "${BASH_SOURCE[0]:-$0}" )"
# @credit: https://github.com/ppo/bash-colors
# @usage:  or copy & paste the `c()` function from:
#          https://github.com/ppo/bash-colors/blob/master/bash-colors.sh#L3
# shellcheck disable=SC2015
test -f "${HERE}/bash-colors.sh" && source "${HERE}/bash-colors.sh" || { c() { :; }; }

declare -r JIRA_URL="${JIRA_URL:-https://jira.domain.com}"
declare -A PROJECTS_ID=( ['PROJ1']='23918' ['PROJ2']='23917' ['PROJ3']='18308' ['PROJ4']='15014' )
declare _PROJECT='PROJ1'
declare -a PROJECTS=()
declare RETURN_TYPE='full'
declare UPDATE_LIMIT=''
declare ASSIGNEE=''
declare REPORTER=''
declare TRANSITION=''
declare COMMENT=''
declare -a KEYS=()
declare -a CURRENT_STATUS=()
declare -A JQL_MAP=(
  ['new']='status in (New, Open)'
  ['in-progress']='status in (Active, "In Progress", "In Review")'
  ['todo']='status in ("To Do")'
  ['open']='status in (Open, New, Active, "To Do", "In Progress", "In Review")'
  ['closed']='status = Closed OR resolution in (Done, Fixed)'
)
# map `--to` target aliases to a comma-separated spec: 'STATUS[,RESOLUTION...]'
declare -A TRANSITION_MAP=(
  ['in-progress']='In Progress'
  ['close']='Closed,Completed,Done,Fixed'
  ['closed']='Closed,Completed,Done,Fixed'
  ['done']='Done,Done'
)

# shellcheck disable=SC2155
declare -r USAGE="NAME
  $(c Ys)${ME}$(c) - List JIRA issues assigned to the current user.

SYNOPSIS
  $(c Ys)\$ ${ME} $(c 0G)[OPTIONS]$(c)

OPTIONS
  $(c G)-p$(c), $(c G)--project $(c 0Mi)PROJECT_KEY$(c)  specify the JIRA project key $(c 0i)(default: $(c 0Mi)'${_PROJECT}'$(c 0i))$(c)
  $(c G)--assignee$(c) $(c 0Mi)USER_ID$(c)         filter issues assigned to the specified user $(c 0i)(no value means $(c 0Mi)currentUser()$(c 0i))$(c)
  $(c G)--reporter$(c) $(c 0Mi)USER_ID$(c)         filter issues reported by the specified user $(c 0i)(no value means $(c 0Mi)currentUser()$(c 0i))$(c)
  $(c G)-u$(c), $(c G)--update $(c 0Mi)FILTER$(c)        filter issues updated within the specified time frame $(c 0i)(e.g., $(c 0Mi)'-4w'$(c 0i) for 4 weeks)$(c)

  $(c B)--open$(c)                     list issues with $(c Bi)status $(c 0i)in ($(c 0Ci)'New'$(c 0i),$(c 0Ci)'Active'$(c 0i),$(c 0Ci)'To Do'$(c 0i),$(c 0Ci)'In Progress'$(c 0i))$(c) $(c 0i)(default)$(c)
  $(c B)--new$(c)                      list issues with $(c Bi)status $(c 0Ci)'New'$(c) or $(c 0Ci)'Active'$(c)
  $(c B)--in-progress$(c)              list issues with $(c Bi)status $(c 0Ci)'In Progress'$(c)
  $(c B)--todo$(c)                     list issues with $(c Bi)status $(c 0Ci)'To Do'$(c)
  $(c B)--closed$(c)                   list issues with $(c Bi)status $(c 0Ci)'Closed'$(c 0i) or $(c Bi)resolution $(c 0i)in ($(c 0Ci)'Done'$(c 0i),$(c 0Ci)'Fixed'$(c 0i))$(c)
                             filter in $(c 0Mi)4 weeks$(c) by default

  $(c Y)--to $(c 0Bi)STATUS$(c)                transition the $(c i)selected$(c) issue to $(c 0Bi)STATUS$(c) $(c 0i)( available: $(c 0Ci)'in-progress'$(c 0i), $(c 0Ci)'close'$(c 0i), $(c 0Ci)'done'$(c 0i))$(c)
  $(c Y)-c$(c), $(c Y)--add-comment $(c 0Mi)TEXT$(c)     add a comment $(c 0Mi)TEXT$(c) to the $(c i)selected$(c) issue

  $(c G)-r$(c), $(c G)--return $(c 0Mi)TYPE$(c)          specify the return format $(c 0i)(default: $(c 0Mi)full$(c 0i))$(c)
                             $(c 0Mi)full$(c) for key and summary; $(c 0Mi)short$(c) for key only
  $(c G)-h$(c), $(c G)--help$(c)                 show this help message and exit

EXAMPLE
  $(c Wdi)# list 2 weeks in-progress jira ticket in project 'PROJID' and 'NEWID' for \`currentUser()\`$(c)
  $(c Ys)\$ ${ME} $(c 0Gi)--project $(c 0Mi)PROJID $(c 0Gi)--project $(c 0Mi)NEWID $(c 0Bi)--in-progress $(c 0Gi)--assignee -u $(c 0Mi)'-2w'$(c)

  $(c Wdi)# list closed and todo tickets in default project for user 'alice' after '2026-03-01 14:30'$(c)
  $(c Ys)\$ ${ME} $(c 0Bi)--todo --closed $(c 0Gi)--assignee $(c 0Mi)alice $(c 0Gi)--update $(c 0Mi)'2026-03-01 14:30'$(c)

  $(c Wdi)# list open tickets, then move the selected one to 'In Progress'$(c)
  $(c Ys)\$ ${ME} $(c 0Bi)--open $(c 0Yi)--to $(c 0Ci)in-progress$(c)

  $(c Wdi)# list open tickets, then add a comment to the selected one$(c)
  $(c Ys)\$ ${ME} $(c 0Bi)--open $(c 0Yi)--add-comment $(c 0Mi)'working on it now'$(c)
"

function passToken() { pass show "${1}" | head -n1; }
function showUsage() { echo -e "${USAGE}"; exit 0;  }
function dieWithCode { echo -e "$(c Ri)ERROR$(c 0i): $1 :$(c)"; shift; echo -e "$(c 0Wi)\`\`\`\n$*\n\`\`\`\n$(c 0Wdi)exit ...$(c)"; exit 1; }
function die()  { echo -e "$(c Ri)ERROR$(c 0i): $*.$(c) $(c Wdi)exit ...$(c)" >&2; exit 1; }
function trim() { IFS='' read -r str; echo "${str}" | sed -e 's/^[[:blank:]]*//;s/[[:blank:]]*$//'; }

declare -r JIRA_API_TOKEN="${JIRA_API_TOKEN:-$( passToken "${PASS_JIRA:-marslo/jira}" )}"
test -n "${JIRA_API_TOKEN:-}" || die "JIRA API token not found. Please set the \`JIRA_API_TOKEN\` environment variable"
declare -ar CURL_CMD=( command curl -u "marslo:${JIRA_API_TOKEN}" --silent --compressed )

# GET the available transitions for a given issue key
#   expand transitions.fields so we can tell whether `resolution` is settable
function getTransitions() {
  "${CURL_CMD[@]}" --get --data-urlencode 'expand=transitions.fields' \
                   "${JIRA_URL}/rest/api/2/issue/${1}/transitions"
}

# transition an issue to a target status via the JIRA API
#   $1: issue key ; $2: target status name (e.g. 'In Progress', 'Closed')
function doTransition() {
  # $2 is a 'STATUS[,RESOLUTION...]' spec (see TRANSITION_MAP)
  local key="$1" spec="$2" target resolutions transitions tid payload resp
  target="${spec%%,*}"
  resolutions=''; [[ "${spec}" == *,* ]] && resolutions="${spec#*,}"
  transitions="$( getTransitions "${key}" )"

  if echo "${transitions}" | jq -e 'has("errorMessages")' >/dev/null 2>&1; then
    dieWithCode 'JIRA API Error' "$(echo "${transitions}" | jq -r '.errorMessages[]')"
  fi

  # prefer matching by the transition's target status name, fallback to transition name
  tid="$( echo "${transitions}" |
          jq -r --arg t "${target}" '.transitions[] | select((.to.name | ascii_downcase) == ($t | ascii_downcase)) | .id' |
          head -n1
        )"
  if [[ -z "${tid}" ]]; then
    tid="$( echo "${transitions}" |
            jq -r --arg t "${target}" '.transitions[] | select((.name | ascii_downcase) == ($t | ascii_downcase)) | .id' |
            head -n1
          )"
  fi
  test -n "${tid}" || die "no transition to '${target}' available for ${key}. available: $(c 0Mi)$( echo "${transitions}" | jq -r '[.transitions[].to.name] | join(", ")' )$(c 0i)"

  # build the payload; when this transition exposes a `resolution` field JIRA requires it to be set explicitly, otherwise resolution defaults to 'Open'
  # try the configured resolution names in order; only names actually offered by the transition are used
  payload="$( echo "${transitions}" | jq -c --arg tid "${tid}" --arg resolutions "${resolutions}" '
    ( .transitions[] | select(.id == $tid) ) as $tr
    | ( $resolutions | if . == "" then [] else split(",") end ) as $prefer
    | { transition: { id: $tid } }
    + ( if ( ($prefer | length) > 0 ) and ( $tr.fields // {} | has("resolution") ) then
          ( $tr.fields.resolution.allowedValues // [] | map(.name) ) as $allowed
          | ( $prefer | map( select( . as $n | $allowed | index($n) ) ) | first ) as $pick
          | if $pick then { fields: { resolution: { name: $pick } } } else {} end
        else {} end )
  ' )"

  resp="$( "${CURL_CMD[@]}" \
           --request POST \
           --header 'Content-Type: application/json' \
           --data "${payload}" \
           "${JIRA_URL}/rest/api/2/issue/${key}/transitions"
         )"
  # a successful transition returns HTTP 204 with an empty body
  if [[ -n "${resp}" ]] && echo "${resp}" | jq -e 'has("errorMessages") or has("errors")' >/dev/null 2>&1; then
    dieWithCode 'JIRA transition failed' "$(echo "${resp}" | jq -rc '.errorMessages, .errors')"
  fi
}

# add a comment to an issue via the JIRA API
#   $1: issue key ; $2: comment body
function addComment() {
  local key="$1" body="$2" payload resp
  payload="$( jq -n --arg b "${body}" '{body: $b}' )"
  resp="$( "${CURL_CMD[@]}" \
           --request POST \
           --header 'Content-Type: application/json' \
           --data "${payload}" \
           "${JIRA_URL}/rest/api/2/issue/${key}/comment"
         )"
  if echo "${resp}" | jq -e 'has("errorMessages") or has("errors")' >/dev/null 2>&1; then
    die "JIRA add comment failed: $(echo "${resp}" | jq -rc '.errorMessages, .errors')"
  fi
  echo "${resp}" | jq -e 'has("id")' >/dev/null 2>&1 || dieWithCode 'JIRA add comment failed' "${resp}"
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    -h | --help             ) showUsage                         ;;
    -r | --return           ) case "${2:-}" in
                                full | short ) RETURN_TYPE="$2" ;;
                                *            ) die "'--return' must be 'full' or 'short', got '$2'" ;;
                              esac
                              shift 2                           ;;
    -p | --project          ) PROJECTS+=( "$2" ) ; shift 2      ;;
    -u | --update           ) UPDATE_LIMIT="$2"  ; shift 2      ;;
    --to                    ) test -n "${2:-}" || die "'--to' requires a target status (e.g. $(IFS=', '; echo "${!TRANSITION_MAP[*]}"))"
                              test -n "${TRANSITION_MAP[${2,,}]:-}" || die "'--to' unknown target '$2' (e.g. $(IFS=', '; echo "${!TRANSITION_MAP[*]}"))"
                              TRANSITION="${TRANSITION_MAP[${2,,}]}"
                              shift 2                           ;;
    -c | --add-comment      ) test -n "${2:-}" || die "'$1' requires a comment text"
                              COMMENT="$2"; shift 2             ;;
    --assignee | --reporter ) PARAM="${1#--}"; PARAM="${PARAM^^}";
                              if [[ -n "${2:-}" && "$2" != -* ]]; then
                                printf -v "${PARAM}" "%s" "$2"; shift 2;
                              else
                                printf -v "${PARAM}" "%s" "currentUser()"; shift 1;
                              fi                                ;;
    --*                     ) KEY="${1#--}"
                              if [[ -n "${JQL_MAP[${KEY}]}" ]]; then
                                KEYS+=( "${KEY}" ); shift ;
                              else
                                die "Unknown option '$1'"
                              fi                                ;;
    *                       ) die "Unknown argument '$1'"       ;;
  esac
done

{ test -z "${ASSIGNEE:-}" && test -z "${REPORTER:-}"; } && ASSIGNEE='currentUser()'
test 0 -eq "${#KEYS[@]}"  && KEYS=( 'open' )

# setup -4w for closed issues by default
for key in "${KEYS[@]}"; do
  jql="${JQL_MAP[${key}]}"
  if [[ "${key}" == "closed" ]] && [[ -z "${UPDATE_LIMIT:-}" ]]; then
    jql="(${jql}) AND updated >= '-4w'"
  fi
  CURRENT_STATUS+=( "(${jql})" )
done

# get final status part
declare STATUS=''
if [[ ${#CURRENT_STATUS[@]} -gt 0 ]]; then
  STATUS=$(IFS='|'; echo "${CURRENT_STATUS[*]}")
  STATUS="${STATUS//|/ OR }"
  # for multiple status ( status=(..) OR status=(..) )
  STATUS="( ${STATUS} )"
fi

declare -a IDS=()
[[ ${#PROJECTS[@]} -eq 0 ]] && PROJECTS=( "${_PROJECT}" )
for p in "${PROJECTS[@]}"; do IDS+=("${PROJECTS_ID[${p}]:-${p}}"); done

#shellcheck disable=SC2155
declare query="project in ($(IFS=', '; echo "${IDS[*]}"))"
query+="${STATUS:+ AND ${STATUS}}"
query+="${ASSIGNEE:+ AND assignee=${ASSIGNEE}}"
query+="${REPORTER:+ AND reporter=${REPORTER}}"
# shellcheck disable=SC2016
query+="${UPDATE_LIMIT:+ AND updated >= '${UPDATE_LIMIT}'}"

declare json=''
json="$( "${CURL_CMD[@]}" --data-urlencode "jql=${query}" --get "${JIRA_URL}/rest/api/2/search" )"

if echo "${json}" | jq -e 'has("errorMessages")' >/dev/null 2>&1; then
  die "JIRA API Error: $(echo "${json}" | jq -r '.errorMessages[]')"
fi

if ! echo "${json}" | jq -e '.issues | length > 0' > /dev/null; then
  echo -e "$(c Wdi)>> $(c 0Mi)No issues found for query:\n$(c 0Wdi)\`\`\`\n${query}\n\`\`\`$(c)" >&2
  exit 0
fi

declare INAME="Marslo Jiao"
declare TEMPLATE='"'
TEMPLATE+='\(.key): \(.fields.summary)'
TEMPLATE+='\t'
TEMPLATE+='Status: '
TEMPLATE+='\(if .fields.status.name | test("Done|Fixed|Closed") then "\\033[1;35m" '
TEMPLATE+='elif .fields.status.name == "To Do" then "\\033[1;90m" '
TEMPLATE+='elif .fields.status.name == "In Progress" then "\\033[1;32m" '
TEMPLATE+='else "\\033[1;36m" end)'
TEMPLATE+='\(.fields.status.name)\\033[0m\n'
TEMPLATE+='Reporter: \(if (.fields.reporter.displayName // "Unknown") != "'"${INAME}"'" then "\\033[0;3m" + (.fields.reporter.displayName // "Unknown") + "\\033[0m" else "\\033[3;36m" + (.fields.reporter.displayName // "Unknown") + "\\033[0m" end) • '
TEMPLATE+='Assignee: \(if (.fields.assignee.displayName // "Unassigned") != "'"${INAME}"'" then "\\033[0;3m" + (.fields.assignee.displayName // "Unassigned") + "\\033[0m" else "\\033[3;36m" + (.fields.assignee.displayName // "Unassigned") + "\\033[0m" end)\n'
TEMPLATE+='Created: \(.fields.created) • Updated: \(.fields.updated)\n\n'
TEMPLATE+='\(.fields.description)'
TEMPLATE+='"'

declare GET_ID="echo {1} | awk -F: '{printf \"%s\", \$1}'"
declare FORMAT_CONTENT="echo {1} | tr -d '\n'"
# shellcheck disable=SC2016
declare TRANSFORMER='
  default_preview=$(( FZF_LINES * 70 / 100 ))
  available=$(( FZF_LINES - FZF_MATCH_COUNT - 4 ))
  if [[ $FZF_MATCH_COUNT -eq 0 ]]; then
    echo "change-preview-window:hidden"
  elif [[ ${available} -gt ${default_preview} ]]; then
    [[ $available -gt 3 ]] && echo "change-preview-window:${available}"
  elif [[ $FZF_PREVIEW_LINES -ne ${default_preview} ]]; then
    echo "change-preview-window:${default_preview}"
  fi
'
declare jira=''
jira="$(
  echo "${json}" | jq ".issues[] | ${TEMPLATE}" |
  sed -e 's/"\(.*\)"/\1/' -e 's/\\"/"/g' -e 's/\\t/\t/g' -e 's/\\\\033/\\033/g' |
  fzf --with-nth=1 --ansi \
      --delimiter='\t' \
      --preview='printf "%b" {2}' \
      --preview-window='top,70%,border-bottom,wrap' \
      --bind "result:transform:${TRANSFORMER}" \
      --bind "resize:transform:${TRANSFORMER}" \
      --bind "ctrl-k:execute-silent(${GET_ID} | pbcopy)" \
      --bind "ctrl-y:execute-silent(${FORMAT_CONTENT} | pbcopy)" \
      --bind "ctrl-o:execute(${GET_ID} | xargs -I {} open ${JIRA_URL}/browse/{})" |
  cut -f1 |
  trim
)"

# act on the selected issue when a `--to-*` / `--add-comment` flag is present
if [[ -n "${TRANSITION:-}" ]] || [[ -n "${COMMENT:-}" ]]; then
  declare KEY_SELECTED=''
  KEY_SELECTED="$( echo "${jira%%:*}" | trim )"
  test -n "${KEY_SELECTED}" || { echo -e "$(c Wdi)>> $(c 0Mi)no issue selected$(c)" >&2; exit 0; }

  if [[ -n "${TRANSITION:-}" ]]; then
    doTransition "${KEY_SELECTED}" "${TRANSITION}"
    echo -e "$(c Gi)>> ${JIRA_URL}/browse/${KEY_SELECTED}$(c)$(c i) transitioned to $(c)$(c 0Ci)'${TRANSITION%%,*}'$(c)"
  fi

  if [[ -n "${COMMENT:-}" ]]; then
    addComment "${KEY_SELECTED}" "${COMMENT}"
    echo -e "$(c Gi)>> ${KEY_SELECTED}$(c)$(c i) comment added$(c)"
  fi

  exit 0
fi

# return
case "${RETURN_TYPE}" in
  short ) echo "${jira%%:*}" | trim ;;
  full  ) echo "${jira}" | trim    ;;
  *     ) die "Invalid return type '${RETURN_TYPE}'" ;;
esac

# awk -F':' '{printf "%s/%s/%s", "sandbox", "marslo", $1}'
# sed -e 's/\. /\t/' -e 's/[^a-zA-Z0-9\t]/-/g' |
# awk '{printf "%s/%s/%s", "issue", $1, tolower($2)}'

# vim:tabstop=2:softtabstop=2:shiftwidth=2:expandtab:filetype=sh:
