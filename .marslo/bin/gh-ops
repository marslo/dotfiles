#!/usr/bin/env bash
# shellcheck source=/dev/null disable=SC2155
#=============================================================================
#     FileName : gh-ops
#       Author : marslo
#      Created : 2026-01-21 20:38:07
#   LastChange : 2026-03-10 21:09:32
#  Inspired by : https://seb.jambor.dev/posts/improving-shell-workflows-with-fzf/
#=============================================================================

set -euo pipefail

declare -r HERE="$( dirname "${BASH_SOURCE[0]:-$0}" )"
declare -r ME="$( basename "${BASH_SOURCE[0]:-$0}" )"
declare -r JQ_FILE="${HERE}/gh.d/gh-ops-preview.jq"

# @credit: https://github.com/ppo/bash-colors
# @usage:  or copy & paste the `c()` function from:
#          https://github.com/ppo/bash-colors/blob/master/bash-colors.sh#L3
# shellcheck disable=SC2015
[[ -f "${HERE}/bash-colors.sh" ]] && source "${HERE}/bash-colors.sh" || { c() { :; }; }

declare -r USAGE="""
NAME
  $(c Cs)${ME}$(c) - interactively GitHub PR using fzf

USAGE
  $(c Ys)\$ ${ME}$(c) $(c Wd)[$(c)$(c Gs)OPTIONS$(c)$(c Wd)]$(c)

OPTIONS
  $(c G)-c$(c), $(c G)--checkout$(c)            checkout the selected pull request ( $(c Cis)*default$(c) )
  $(c G)-C$(c), $(c G)--close$(c)               close the selected pull request
  $(c G)-o$(c), $(c G)--open$(c)                open the selected pull request in the web browser
  $(c G)-A$(c), $(c G)--auto-open$(c)           automatically open the PR in the web browser after selection
  $(c G)-s$(c), $(c G)--squash$(c)              squash merge the selected pull request and delete the branch
  $(c G)-r$(c), $(c G)--rebase$(c)              rebase merge the selected pull request and delete
  $(c G)-l$(c), $(c G)--label$(c) $(c 0Mi)LABEL$(c)         add label(s) to the selected pull request $(c 0i)(default:  using fzf to select)$(c)
  $(c G)-L$(c), $(c G)--remove-label$(c) $(c 0Mi)LABEL$(c)  remove label(s) from the selected pull request $(c 0i)(default:  using fzf to select)$(c)
  $(c G)-S$(c), $(c G)--state$(c) $(c 0Mi)STATE$(c)         filter PR by state $(c 0i)(e.g. $(c 0Ci)open$(c 0i), $(c 0Ci)closed$(c 0i), $(c 0Ci)all$(c 0i), $(c 0Ci)merged$(c 0i))$(c)
  $(c G)-B$(c), $(c G)--base$(c) $(c 0Mi)BRANCH_NAME$(c)    filter PR by base branch
  $(c G)-R$(c), $(c G)--repo$(c) $(c 0Mi)OWNER/REPO$(c)     filter PR by repository $(c 0i)(e.g. $(c 0Ci)OWNER/REPO$(c 0i))$(c)
  $(c G)-V$(c), $(c G)--verbose$(c)             show verbose output
  $(c G)--dryrun$(c)                  show the command to be executed, but do not run it
  $(c G)-h$(c), $(c G)--help$(c)                show this help message
  $(c C)--$(c) $(c 0Mi)GH_OPTIONS$(c)             pass all following arguments to gh CLI $(c 0i)(e.g. $(c 0Ci)--auto$(c 0i), $(c 0Ci)--delete-branch$(c)$(c 0i), etc.)$(c)

EXAMPLES
  $(c Wdi)# interactively select a pull request and checkout the corresponding branch$(c)
  $(c 0Ys)\$ ${ME} $(c 0Wdi)or $(c 0Ys)\$ ${ME} $(c 0Gi)--checkout$(c)

  $(c Wdi)# update all submodules after checkout$(c)
  $(c Ys)\$ ${ME} $(c 0Gi)--checkout $(c 0Ci)-- $(c 0Mi)--recurse-submodules$(c)

  $(c Wdi)# close the PR and delete the branch$(c)
  $(c Ys)\$ ${ME} $(c 0Gi)--close $(c 0Ci)-- $(c 0Mi)--delete-branch$(c)

  $(c Wdi)# add label(s) to the closed PR$(c)
  $(c Ys)\$ ${ME} $(c 0Gi)--label $(c 0Mi)bug,help $(c 0Gi)--state $(c 0Mi)closed$(c)$(c)
  $(c Ys)\$ ${ME} $(c 0Gi)--label $(c 0Mi)bug $(c 0Gi)--label $(c 0Mi)help $(c 0Gi)--state $(c 0Mi)closed$(c)$(c)

TIPS
  while in the fzf selection menu:
    • press $(c 0Bsi)ctrl-y$(c) to copy the PR ID to clipboard
    • press $(c 0Bsi)ctrl-o$(c) to open the selected PR in the web browser
    • press $(c 0Bsi)ctrl-/$(c) to toggle between local and remote preview (requires the preview script to be present)
"""

declare OPTION=''
declare DRYRUN=false
declare VERBOSE=false
declare -a GH_OPTS=()
declare -a CLI_OPTS=()
declare -a CLI_CMD=( gh )
declare SHOULD_OPEN=false
declare AUTO_OPEN=false

function showHelp() { echo -e "${USAGE}"; exit 0; }
function show() {
  local tag tcolor body
  local extra=''
  local bcolor="$(c 0Wi)"

  case "$1" in
    info             ) tag="$1";    shift; body="${*}"; tcolor="$(c 0Gi)"                      ;;
    warning          ) tag="$1";    shift; body="${*}"; tcolor="$(c 0Yi)"                      ;;
    error            ) tag="$1";    shift; body="${*}"; tcolor="$(c 0Ri)"                      ;;
    dryrun | verbose ) tag=">> $1"; shift; body="${*}"; tcolor="$(c 0Wdi)"; bcolor="${tcolor}" ;;
    *                ) tag='error';        body="${*}"; tcolor="$(c 0Ri)"                      ;;
  esac

  [[ 'error' == "${tag}" ]] && extra="$(c Wdi). exit ...$(c)" || extra=''
  printf "%b%s$(c)%b: %b$(c)%b\n" "${tcolor}" "${tag^^}" "${bcolor}" "${body}" "${extra}" >&2;
  [[ 'error' == "${tag}" ]] && exit 1 || :
}

function joinBy {
  local d=${1-} f=${2-}
  if shift 2; then printf %s "$f" "${@/#/$d}"; fi
}

function checkTools() {
  local -a tools=( 'gh' 'fzf' )
  local -a missing=()

  for tool in "${tools[@]}"; do
    type -P "${tool}" >/dev/null 2>&1 || missing+=( "${tool}" )
  done

  if [[ ${#missing[@]} -gt 0 ]]; then
    show error "missing required tools: $(c 0Mi)$(joinBy ', ' "${missing[@]}")$(c)"
  fi
}

function openPR() {
  local id="${1:-}"

  if "${SHOULD_OPEN}"; then
    "${AUTO_OPEN}" && {
      test -z "${id:-}" && id="$(gh pr view --json number -q .number 2>/dev/null)"
    }
    # shellcheck disable=SC2015
    test -n "${id:-}" && {
      local -a openCmd=( gh pr view "${id}" --web )
      "${VERBOSE}" && show info "opening PR $(c 0Mi)\`#${id}\`$(c 0Wdi) in web browser ...$(c)" || :
      "${openCmd[@]}"
    } || {
      show warning "cannot open PR: no PR ID found"
    }
  fi
}

# shellcheck disable=SC2015,SC2059
function jc() {
  [ $# == 0 ] && printf "\\u001b[0m" || \
  printf "${1}" | sed 's/\(.\)/\1;/g;s/\([SDIUFNHT]\)/1\1/g;s/\([KRGYBMCW]\)/3\1/g;s/\([krgybmcw]\)/4\1/g;y/SDIUFNHTsdiufnhtKRGYBMCWkrgybmcw/12345789123457890123456701234567/;s/^\(.*\);$/\\u001b[\1m/g'
}

# shellcheck disable=SC2016,SC2064
function getId() {
  test -f "${JQ_FILE}" || show error "missing JQ filter file at ${JQ_FILE}"
  export JQ_FILTER="$(cat "${JQ_FILE}")"

  local CACHE_FILE="/tmp/gh_ops_cache_$$"
  trap "rm -f ${CACHE_FILE}" EXIT
  : > "${CACHE_FILE}"

  local TEMPLATE='"'
  TEMPLATE+='#\(.number) - \(.title)'
  TEMPLATE+='\t'
  TEMPLATE+="$(jc Cs)Author:$(jc) \(.author.login)\n"
  TEMPLATE+="$(jc Ys)Created:$(jc) \(.createdAt) $(jc Ms)•$(jc) $(jc Ys)Updated:$(jc) \(.updatedAt)\n\n"
  TEMPLATE+='\(.title)'
  TEMPLATE+='\( .title as $t | (.body // "") | if startswith($t) then .[($t | length):] else . end | gsub("(?s)[ \t]*<!--.*?-->[ \t]*\n?"; "") | sub("^\\s+"; "") | if . == "" then "" else "\n\n" + . end )'
  TEMPLATE+='"'

  local EXTRACT_ID_CMD='sed -n "$(( {n}+1 ))p" "'${CACHE_FILE}'" | sed -En "s/^#([0-9]+).*/\1/p"'

  local REMOTE_CMD=''
  REMOTE_CMD+='change-preview('
  REMOTE_CMD+='id=$( '${EXTRACT_ID_CMD}' ); '
  REMOTE_CMD+='if [ -n "${id}" ]; then gh pr view "${id}" --json mergeable,reviewDecision,reviewRequests,reviews,body,labels,state --jq "$JQ_FILTER" 2>/dev/null; else echo "Loading Remote ..."; fi'
  REMOTE_CMD+=')+'
  REMOTE_CMD+='transform-preview-label('
  REMOTE_CMD+='id=$( '${EXTRACT_ID_CMD}' ); '
  REMOTE_CMD+='printf "\033[1;36m[ REMOTE #%s ]\033[0m" "${id}"'
  REMOTE_CMD+=')'
  export CMD_REMOTE="${REMOTE_CMD}"

  local LOCAL_CMD=''
  LOCAL_CMD+='change-preview('
  LOCAL_CMD+='content=$( sed -n "$(({n}+1))p" "'${CACHE_FILE}'" | cut -f2- ); '
  LOCAL_CMD+='printf "%b\n" "${content}"'
  LOCAL_CMD+=')+'
  LOCAL_CMD+='transform-preview-label('
  LOCAL_CMD+='id=$( '${EXTRACT_ID_CMD}' ); '
  LOCAL_CMD+='printf "\033[1;35m[ LOCAL #%s ]\033[0m" "${id}"'
  LOCAL_CMD+=')'
  export CMD_LOCAL="${LOCAL_CMD}"

  # result:transform-list-label
  local BIND_RESULT_CMD='if [[ -z ${FZF_QUERY} ]]; then echo " ${FZF_MATCH_COUNT} items "; else echo " ${FZF_MATCH_COUNT} matches for [${FZF_QUERY}] "; fi'

  # focus:transform-preview-label
  local BIND_FOCUS_CMD=''
  BIND_FOCUS_CMD+='id=$( '${EXTRACT_ID_CMD}' ); '
  BIND_FOCUS_CMD+='if echo "${FZF_PREVIEW_LABEL}" | grep -q -i "remote"; then '
  BIND_FOCUS_CMD+='  printf "\033[1;36m[ REMOTE #%s ]\033[0m" "${id}"; '
  BIND_FOCUS_CMD+='else '
  BIND_FOCUS_CMD+='  printf "\033[1;35m[ LOCAL #%s ]\033[0m" "${id}"; '
  BIND_FOCUS_CMD+='fi'

  # ctrl-/:transform
  local BIND_TOGGLE_CMD=''
  BIND_TOGGLE_CMD+='if echo "${FZF_PREVIEW_LABEL}" | grep -q -i "remote"; then '
  BIND_TOGGLE_CMD+='  echo "${CMD_LOCAL}"; '
  BIND_TOGGLE_CMD+='else '
  BIND_TOGGLE_CMD+='  echo "${CMD_REMOTE}"; '
  BIND_TOGGLE_CMD+='fi'

  local PR_ID=''
  CLI_CMD+=( pr list --json 'number,title,author,createdAt,updatedAt,body' )
  CLI_CMD+=( "${CLI_OPTS[@]}" )
  PR_ID=$(
    "${CLI_CMD[@]}" | jq ".[] | ${TEMPLATE}" |
    sed -e 's/"\(.*\)"/\1/' -e 's/\\t/\t/' -e 's/\\u001b/\\033/g' |
    tee "${CACHE_FILE}" |
    fzf +m --ansi \
        --with-nth=1 \
        --delimiter='\t' \
        --color='query:bold:italic:magenta,prompt:italic' \
        --preview-window=top:65%:wrap \
        --prompt=' PR: ' --info='inline-right:  ' \
        --preview='content=$(sed -n "$(( {n}+1 ))p" "'${CACHE_FILE}'" | cut -f2-); printf "%b\n" "${content}"' \
        --preview-label=$'\033[1;35m[ Local ]\033[0m' \
        --bind "result:transform-list-label:${BIND_RESULT_CMD}" \
        --bind "focus:transform-preview-label:${BIND_FOCUS_CMD}" \
        --bind "ctrl-/:transform:${BIND_TOGGLE_CMD}" \
        --bind "ctrl-y:execute-silent(echo {1} | sed -En 's/^#([0-9]+).*/\1/p' | pbcopy)" \
        --bind "ctrl-o:execute-silent(echo {1} | awk '{print \$1}' | xargs gh pr view --web)" |
    sed -En 's/^#([0-9]+).*/\1/p'
  )

  unset JQ_FILTER CMD_REMOTE CMD_LOCAL
  test -n "${PR_ID}" && echo "${PR_ID}" || return 1
}

function getLabel() {
  local nowLabels
  nowLabels="$( gh pr view "${PR_ID}" --json labels --jq '.labels[].name' )"

  case "$1" in
    --add-label    ) local allLabels
                     allLabels="$( gh label list --json name --jq '.[].name' )"
                     comm -23 <( sort <<< "${allLabels}" ) <( sort <<< "${nowLabels}" ) \
                       | fzf --ansi --prompt='󰩀 add > ' -0 -m | paste -sd "," - ;;
    --remove-label ) if [[ -z "${nowLabels:-}" ]]; then
                       show error "no labels on PR #${PR_ID}"
                       return 1
                     fi
                     sort <<< "${nowLabels}" \
                       | fzf --ansi --prompt='󰩀 remove > ' -0 -m | paste -sd "," - ;;
  esac
}

function main() {
  local -a LABELS=()
  local -A MAPPING=(
    ['-c']='checkout'  ['-C']='close'
    ['-s']='squash'    ['-r']='rebase'
    ['-l']='add-label' ['-L']='remove-label'
    ['-S']='state'     ['-B']='base'    ['-R']='repo'
  )

  while [[ $# -gt 0 ]]; do
    case "$1" in
      -l | --add-label  | \
      -L | --remove-label ) OPTION="${MAPPING[$1]:-${1#--}}" ;
                            if [[ -n "${2:-}" && "${2}" != -* ]]; then
                              LABELS+=("${2}"); shift;
                            fi                               ; shift ;;
      -c | --checkout   | \
      -C | --close      | \
      -s | --squash     | \
      -r | --rebase       ) OPTION="${MAPPING[$1]:-${1#--}}" ; shift ;;
      -o | --open         ) SHOULD_OPEN=true                 ; shift ;;
      -A | --auto-open    ) SHOULD_OPEN=true; AUTO_OPEN=true ; shift ;;
      -V | --verbose      ) VERBOSE=true                     ; shift ;;
      --dryrun            ) DRYRUN=true                      ; shift ;;
      -S | --state      | \
      -B | --base       | \
      -R | --repo         ) CLI_OPTS+=( "--${MAPPING[$1]:-${1#--}}" "$2" ); shift 2 ;;
      --                  ) shift ; GH_OPTS+=( "$@" )        ; break ;;
      -h | --help         ) showHelp                                 ;;
      *                   ) show error "unknown argument: \`$1\`"    ;;
    esac
  done

  checkTools

  local -a LABEL=''
  [[ "${#LABELS[@]}" -gt 0 ]] && LABEL="$( joinBy ',' "${LABELS[@]}" )"

  # shellcheck disable=SC2155
  local PR_ID="$( getId )"
  test -z "${PR_ID}" && exit 0
  local cmd=( gh pr )
  case "${OPTION:-}" in
    checkout | close         ) cmd+=( "${OPTION}" "${PR_ID}"    )          ;;
    squash                   ) cmd+=( merge "${PR_ID}" --squash )          ;;
    rebase                   ) cmd+=( merge "${PR_ID}" --rebase )          ;;
    add-label | remove-label ) test -n "${LABEL}" || LABEL="$( getLabel "--${OPTION}")"
                               test -n "${LABEL}" && cmd+=( edit "${PR_ID}" "--${OPTION}" "${LABEL}" ) ;;
    *                        ) test -n "${OPTION:-}" && show error "unknown option: \`${OPTION}\`"  ;;
  esac

  [[ -z "${OPTION}" && "${SHOULD_OPEN}" ]] && { openPR "${PR_ID}"; exit 0; }

  { "${DRYRUN}" || "${VERBOSE}"; } && {
    local msg="command to be executed: \`$(c 0Cdi)\$ ${cmd[*]}${GH_OPTS[*]:+ ${GH_OPTS[*]}}$(c 0Wdi)\` ...$(c)"
    # shellcheck disable=SC2015
    "${DRYRUN}" && { show dryrun "${msg}"; exit 0; } || show verbose "${msg}"
  }

  local _extra=''; [[ "${OPTION}" == 'add-label' ]] && _extra='to' || _extra='from'
  # shellcheck disable=SC2016
  printf "$(c Ci)~~> %s$(c)%b $(c 0Mis)#%s$(c)%b $(c Ci)..$(c)\n" \
         "${OPTION}" \
         "${LABEL:+ $(c 0Mis)'${LABEL}'} $(c 0Ci)${_extra}" \
         "${PR_ID}" \
         "${GH_OPTS[*]:+ $(c 0i)with gh OPTS $(c 0Mis)${GH_OPTS[*]}$(c)}" >&2

  "${cmd[@]}" "${GH_OPTS[@]}"

  [[ -n "${OPTION}" && "${SHOULD_OPEN}" ]] && { openPR "${PR_ID}"; exit 0; }
}

main "$@"

# vim:tabstop=2:softtabstop=2:shiftwidth=2:expandtab:filetype=sh:
