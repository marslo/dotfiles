#!/usr/bin/env bash
# shellcheck source=/dev/null disable=SC2155
#=============================================================================
#     FileName : gh-ops
#       Author : marslo
#      Created : 2026-01-21 20:38:07
#   LastChange : 2026-03-20 01:31:09
#  Inspired by : https://seb.jambor.dev/posts/improving-shell-workflows-with-fzf/
#=============================================================================

set -euo pipefail

declare -r HERE="$( dirname "${BASH_SOURCE[0]:-$0}" )"
declare -r ME="$( basename "${BASH_SOURCE[0]:-$0}" )"

# @credit: https://github.com/ppo/bash-colors
# @usage:  or copy & paste the `c()` function from:
#          https://github.com/ppo/bash-colors/blob/master/bash-colors.sh#L3
# shellcheck disable=SC2015
[[ -f "${HERE}/bash-colors.sh" ]] && source "${HERE}/bash-colors.sh" || { c() { :; }; }
# shellcheck disable=SC2015
[[ -f "${HERE}/gh.d/gh-preview" ]] && source "${HERE}/gh.d/gh-preview" || {
  echo -e "$(c 0Rs)ERROR: missing dependency: $(c 0Mi)\`gh-preview\` $(c 0Wi)script not found. please make sure it is present in the same directory or in the PATH$(c)" >&2
  exit 1
}

declare -r USAGE="NAME
  $(c Cs)${ME}$(c) - interactively GitHub PR using fzf

USAGE
  $(c Ys)\$ ${ME}$(c) $(c Wd)[$(c)$(c Gs)OPTIONS$(c)$(c Wd)]$(c)

OPTIONS
  $(c G)-c$(c), $(c G)--checkout$(c)            checkout the selected pull request ( $(c Cis)*default$(c) )
  $(c G)-C$(c), $(c G)--close$(c)               close the selected pull request
  $(c G)-o$(c), $(c G)--open$(c)                open the selected pull request in the web browser
  $(c G)-A$(c), $(c G)--auto-open$(c)           automatically open the PR in the web browser after selection
  $(c G)-s$(c), $(c G)--squash$(c)              squash merge the selected pull request and delete the branch
  $(c G)-r$(c), $(c G)--rebase$(c)              rebase merge the selected pull request and delete
  $(c G)-l$(c), $(c G)--add-label$(c) $(c 0Mi)LABEL$(c)     add label(s) to the selected pull request $(c 0i)(default:  using fzf to select)$(c)
  $(c G)-L$(c), $(c G)--remove-label$(c) $(c 0Mi)LABEL$(c)  remove label(s) from the selected pull request $(c 0i)(default:  using fzf to select)$(c)
  $(c G)-M$(c), $(c G)--comment$(c) $(c 0Mi)MESSAGE$(c)     add a review comment to the selected pull request with message
  $(c G)-a$(c), $(c G)--approve$(c) $(c 0Mi)<MESSAGE>$(c)   approve the selected pull request with or without message
  $(c G)--request-changes$(c) $(c 0Mi)MESSAGE$(c) request changes on the selected pull request with message
  $(c G)-S$(c), $(c G)--state$(c) $(c 0Mi)STATE$(c)         filter PR by state $(c 0i)(e.g. $(c 0Ci)open$(c 0i), $(c 0Ci)closed$(c 0i), $(c 0Ci)all$(c 0i), $(c 0Ci)merged$(c 0i))$(c)
  $(c G)-B$(c), $(c G)--base$(c) $(c 0Mi)BRANCH_NAME$(c)    filter PR by base branch
  $(c G)-R$(c), $(c G)--repo$(c) $(c 0Mi)OWNER/REPO$(c)     filter PR by repository $(c 0i)(e.g. $(c 0Ci)OWNER/REPO$(c 0i))$(c)
  $(c G)-v$(c), $(c G)--verbose$(c)             show verbose output
  $(c G)--dryrun$(c)                  show the command to be executed, but do not run it
  $(c G)-h$(c), $(c G)--help$(c)                show this help message
  $(c C)--$(c) $(c 0Mi)GH_OPTIONS$(c)             pass all following arguments to gh CLI $(c 0i)(e.g. $(c 0Ci)--auto$(c 0i), $(c 0Ci)--delete-branch$(c)$(c 0i), etc.)$(c)

EXAMPLES
  $(c Wdi)# interactively select a pull request and checkout the corresponding branch$(c)
  $(c 0Ys)\$ ${ME} $(c 0Gi)--checkout$(c)

  $(c Wdi)# update all submodules after checkout$(c)
  $(c Ys)\$ ${ME} $(c 0Gi)--checkout $(c 0Ci)-- $(c 0Mi)--recurse-submodules$(c)

  $(c Wdi)# close the PR and delete the branch$(c)
  $(c Ys)\$ ${ME} $(c 0Gi)--close $(c 0Ci)-- $(c 0Mi)--delete-branch$(c)

  $(c Wdi)# add label(s) to the closed PR$(c)
  $(c Ys)\$ ${ME} $(c 0Gi)--add-label $(c 0Mi)bug,help $(c 0Gi)--state $(c 0Mi)closed$(c)$(c)
  $(c Ys)\$ ${ME} $(c 0Gi)--add-label $(c 0Mi)bug $(c 0Gi)--add-label $(c 0Mi)help $(c 0Gi)--state $(c 0Mi)closed$(c)$(c)

  $(c Wdi)# approve the PR$(c)
  $(c Ys)\$ ${ME} $(c 0Gi)--approve$(c)
  $(c Ys)\$ ${ME} $(c 0Gi)--approve $(c 0Mi)'looks good to me'$(c)

  $(c Wdi)# comment on the PR - to trigger the Jenkins pipeline with keyword$(c)
  $(c Ys)\$ ${ME} $(c 0Gi)--comment $(c 0Mi)'cri'$(c)

TIPS
  while in the fzf selection menu:
    • press $(c 0Bsi)ctrl-y$(c) to copy the PR ID to clipboard
    • press $(c 0Bsi)ctrl-o$(c) to open the selected PR in the web browser
    • press $(c 0Bsi)ctrl-/$(c) to toggle between local and remote preview (requires the preview script to be present)
"

declare DRYRUN=false
declare VERBOSE=false
declare OPEN=false
declare AUTO=false
declare -a CLI_CMD=( gh pr )
declare -a CLI_OPTS=()
declare -a GH_OPTS=()
declare -a GHD_OPTS=()
declare -a REVIEW_ARGS=()
declare -a OPTIONS=()
declare REPO_PATH=''

function showHelp() { echo -e "${USAGE}"; exit 0; }
function _output() {
  local _extra='' _option='' _body=''
  _hasOption 'add-label' && _extra='to' || _extra='from'
  _hasOption 'review'    && {
    [[ ${#REVIEW_ARGS[@]} -gt 0 ]] && { _option="${REVIEW_ARGS[0]#--}"; _extra='on'; } || :
    [[ ${#REVIEW_ARGS[@]} -eq 3 ]] && _body="${REVIEW_ARGS[2]}"                        || :
  } || _option="$(joinBy ' and ' "${OPTIONS[@]}")"

  # shellcheck disable=SC2016
  printf "$(c Ci)~~> %s$(c)%b $(c 0Mis)%s #%s$(c)%b%b $(c Ci)..$(c)\n" \
         "${_option}" \
         "${LABEL:+ $(c 0Mis)'${LABEL}'} $(c 0Ci)${_extra}" \
         "${REPO_PATH}" \
         "${PR_ID}" \
         "${_body:+ $(c 0Ci)with message $(c 0Bi)'${_body}'$(c)}" \
         "${GH_OPTS[*]:+ $(c 0i)with gh OPTS $(c 0Mis)${GH_OPTS[*]}$(c)}" >&2
}

function show() {
  local tag tcolor body
  local extra=''
  local bcolor="$(c 0Wi)"

  case "$1" in
    info             ) tag="$1";    shift; body="${*}"; tcolor="$(c 0Gi)"                      ;;
    warning          ) tag="$1";    shift; body="${*}"; tcolor="$(c 0Yi)"                      ;;
    error            ) tag="$1";    shift; body="${*}"; tcolor="$(c 0Ri)"                      ;;
    dryrun | verbose ) tag=">> $1"; shift; body="${*}"; tcolor="$(c 0Wdi)"; bcolor="${tcolor}" ;;
    action           ) _output; return 0                                                       ;;
    *                ) tag='error';        body="${*}"; tcolor="$(c 0Ri)"                      ;;
  esac

  [[ 'error' = "${tag}" ]] && extra="$(c Wdi). exit ...$(c)" || extra=''
  printf "%b%s$(c)%b: %b$(c)%b\n" "${tcolor}" "${tag^^}" "${bcolor}" "${body}" "${extra}" >&2;
  [[ 'error' = "${tag}" ]] && exit 1 || :
}

function joinBy {
  local d=${1-} f=${2-}
  if shift 2; then printf %s "$f" "${@/#/$d}"; fi
}

function _hasOption() { [[ " ${OPTIONS[*]} " == *" $1 "* ]]; }
function _checkReviewOptions() { [[ ${#REVIEW_ARGS[@]} -gt 0 ]] && show error "--comment/--approve/--request-changes are mutually exclusive" || :; }
function _dryrun()  { "${DRYRUN}"  && { show dryrun  "${1}"; exit 0; }; }
function _verbose() { "${VERBOSE}" && show verbose "${1}" || :        ; }
function _dryrunOrVerbose() { _dryrun "${1}" || _verbose "${1}"       ; }

function checkTools() {
  local -a tools=( 'gh' 'fzf' )
  local -a missing=()

  for tool in "${tools[@]}"; do
    type -P "${tool}" >/dev/null 2>&1 || missing+=( "${tool}" )
  done

  if [[ ${#missing[@]} -gt 0 ]]; then
    show error "missing required tools: $(c 0Mi)$(joinBy ', ' "${missing[@]}")$(c)"
  fi
}

function openPR() {
  local id="${1:-}"

  if "${OPEN}"; then
    # shellcheck disable=SC2015
    test -n "${id:-}" && {
      local -a openCmd=( "${CLI_CMD[@]}" view "${id}" --web )
      _dryrun  "command to be executed: \`$(c 0Cdi)\$ ${openCmd[*]}$(c 0Wdi)\` ...$(c)"
      _verbose "opening PR $(c 0Mi)\`#${id}\`$(c 0Wdi) in web browser ...$(c)"
      "${openCmd[@]}"
    } || {
      show warning "cannot open PR: no PR ID found"
    }
  fi
}

function getLabel() {
  local _labels
  _labels="$( "${CLI_CMD[@]}" view "${PR_ID}" --json labels --jq '.labels[].name' )"

  case "$1" in
    --add-label    ) local allLabels
                     allLabels="$( gh label list --json name --jq '.[].name' )"
                     comm -23 <( sort <<< "${allLabels}" ) <( sort <<< "${_labels}" ) \
                       | fzf --ansi --prompt='󰩀 add > ' -0 -m | paste -sd "," - ;;
    --remove-label ) if [[ -z "${_labels:-}" ]]; then
                       show error "no labels on PR #${PR_ID}"
                       return 1
                     fi
                     sort <<< "${_labels}" \
                       | fzf --ansi --prompt='󰩀 remove > ' -0 -m | paste -sd "," - ;;
  esac
}

function main() {
  local -a LABELS=()
  local -A MAPPING=(
    ['-c']='checkout'  ['-C']='close'
    ['-s']='squash'    ['-r']='rebase'
    ['-l']='add-label' ['-L']='remove-label'
    ['-S']='state'     ['-B']='base'    ['-R']='repo'
    ['-M']='review'    ['--comment']='review'
    ['-a']='review'    ['--approve']='review'
    ['--request-changes']='review'
  )

  while [[ $# -gt 0 ]]; do
    case "$1" in
      -l | --add-label  | \
      -L | --remove-label ) OPTIONS+=("${MAPPING[$1]:-${1#--}}") ;
                            if [[ -n "${2:-}" && "${2}" != -* ]] ; then
                              IFS=',' read -ra _label <<< "${2}"; LABELS+=("${_label[@]}"); shift;
                            fi                                   ; shift ;;
      -c | --checkout   | \
      -C | --close      | \
      -s | --squash     | \
      -r | --rebase       ) OPTIONS+=("${MAPPING[$1]:-${1#--}}") ; shift ;;
      -o | --open         ) OPEN=true                            ; shift ;;
      -A | --auto-open    ) OPEN=true; AUTO=true                 ; shift ;;
      -v | --verbose      ) VERBOSE=true                         ; shift ;;
      --dryrun            ) DRYRUN=true                          ; shift ;;
      --request-changes | \
      -M | --comment      ) _checkReviewOptions; OPTIONS+=("${MAPPING[$1]}") ;
                            [[ -z "${2:-}" || "${2}" == -* ]] && show error "${1} requires a body message"
                            local rarg; [[ 'request-changes' = "${1#--}" ]] && rarg='--request-changes' || rarg='--comment'
                            REVIEW_ARGS+=( "${rarg}" --body "${2}" ) ; shift 2 ;;
      -a | --approve      ) _checkReviewOptions; OPTIONS+=("${MAPPING[$1]}") ;
                            REVIEW_ARGS+=( --approve ) ;
                            [[ -n "${2:-}" && "${2}" != -* ]] && { REVIEW_ARGS+=( --body "${2}" ); shift ;} ;
                            shift ;;
      -S | --state      | \
      -B | --base         ) GHD_OPTS+=( "--${MAPPING[$1]:-${1#--}}" "$2" ) ; shift 2 ;;
      -R | --repo         ) GHD_OPTS+=( "--${MAPPING[$1]:-${1#--}}" "$2" ) ;
                            CLI_CMD+=( "--${MAPPING[$1]:-${1#--}}" "$2" )  ;
                            REPO_PATH="${2}"                               ; shift 2 ;;
      --                  ) shift ; GH_OPTS+=( "$@" )                      ; break   ;;
      -h | --help         ) showHelp                                      ;;
      *                   ) show error "unknown argument: \`$1\`"         ;;
    esac
  done

  # uniq (guard against empty array producing a blank line that mapfile would capture)
  [[ ${#OPTIONS[@]} -gt 0 ]] && mapfile -t OPTIONS < <(printf '%s\n' "${OPTIONS[@]}" | sort -u) || OPTIONS=()
  REPO_PATH="${REPO_PATH:-$( gh repo view --json nameWithOwner -q .nameWithOwner 2>/dev/null )}"

  local LABEL=''
  [[ "${#LABELS[@]}" -gt 0 ]] && LABEL="$( joinBy ',' "${LABELS[@]}" )"

  local PR_ID=''
  "${AUTO}" && PR_ID="$( gh pr view --json number -q .number 2>/dev/null )" || PR_ID="$( getPRId "${GHD_OPTS[@]}" )"
  test -z "${PR_ID}" && exit 0

  for option in "${OPTIONS[@]}"; do
    case "${option}" in
      checkout | close         ) CLI_OPTS+=( "${option}" "${PR_ID}"    )                   ;;
      squash                   ) CLI_OPTS+=( merge "${PR_ID}" --squash )                   ;;
      rebase                   ) CLI_OPTS+=( merge "${PR_ID}" --rebase )                   ;;
      review                   ) CLI_OPTS+=( "${option}" "${PR_ID}" "${REVIEW_ARGS[@]}" )  ;;
      add-label | remove-label ) test -n "${LABEL:-}" || LABEL="$( getLabel "--${option}")" ;
                                 test -n "${LABEL:-}" && CLI_OPTS+=( edit "${PR_ID}" "--${option}" "${LABEL}" ) ;;
      *                        ) show error "unknown option: \`${option}\`"                ;;
    esac
  done

  [[ 0 = "${#OPTIONS[@]}" ]] && "${OPEN}" && { openPR "${PR_ID}"; exit 0; }

  # show info
  _dryrunOrVerbose "command to be executed: \`$(c 0Cdi)\$ ${CLI_CMD[*]}${CLI_OPTS[*]:+ ${CLI_OPTS[*]}}${GH_OPTS[*]:+ ${GH_OPTS[*]}}$(c 0Wdi)\` ...$(c)"
  show action

  # run cli
  "${CLI_CMD[@]}" "${CLI_OPTS[@]}" "${GH_OPTS[@]}"

  "${OPEN}" && { openPR "${PR_ID}"; exit 0; } || :
}

checkTools
main "$@"

# vim:tabstop=2:softtabstop=2:shiftwidth=2:expandtab:filetype=sh:
