#!/usr/bin/env bash
# shellcheck source=/dev/null
#=============================================================================
#     FileName : git-del
#       Author : marslo
#      Created : 2023-12-14 17:55:55
#   LastChange : 2026-05-22 17:52:02
#  Description : delete branch or tag from remote and/or local
#                -  - E0A0/E725
#=============================================================================

# shellcheck disable=SC2155
declare -r HERE="$( dirname "${BASH_SOURCE[0]:-$0}" )"
# @credit: https://github.com/ppo/bash-colors
# @usage:  or copy & paste the `c()` function from:
#          https://github.com/ppo/bash-colors/blob/master/bash-colors.sh#L3
source "${HERE}/bash-colors.sh" 2>/dev/null || { c() { :; }; }

declare BRANCHES=''
declare TAGS=''
# both, local, remote
declare MODE='both'
declare BRANCH_FOUND=0
declare TAG_FOUND=0
declare REMOTE_REF=''
declare refname=''
# shellcheck disable=SC2155
declare -r ME="$(basename "${BASH_SOURCE[0]:-$0}" | tr '-' ' ')"
# shellcheck disable=SC2155
declare USAGE="""
NAME
  $(c Ysi)${ME}$(c) - $(c Ysi)del$(c)ete a Git branch or tags locally or remotely

USAGE
  $(c Ys)\$ ${ME} $(c 0Wdi)[$(c 0Gi)OPTIONS$(c 0Wdi)]$(c) $(c 0Wdi)[$(c 0Bi)branch|tag$(c 0Wdi)]$(c)

OPTIONS
  $(c Gi)-r$(c), $(c Gi)--remote$(c)        delete only the remote branch
  $(c Gi)-l$(c), $(c Gi)--local$(c)         delete only the local branch or tag
  $(c Gi)-h$(c), $(c Gi)--help$(c)          show this help message

EXAMPLES
  $(c Ys)\$ ${ME} $(c 0Mi)feature/foo$(c)        $(c Wdi)# delete both local and remote branch 'feature/foo'$(c)
  $(c Ys)\$ ${ME} $(c 0Gi)-r $(c 0Mi)feature/foo$(c)     $(c Wdi)# delete remote branch 'feature/foo'$(c)
"""

function die()      { echo -e "$(c Ri)ERROR$(c)$(c i): $*.$(c) $(c Wdi)exit ...$(c)" >&2; exit 1; }
function showHelp() { echo -e "${USAGE}"; exit 0; }
function info()     { echo -e "$(c Wd)>>$(c) $*$(c)"; }
function success()  { info "$(c Wdi)$1 :$(c) $(c Mis)$2$(c) $(c Wdi)$3$(c)"; }
function warn()     { info "$(c Mis)$1$(c) $(c Wdi)$2$(c)"; }
# shellcheck disable=SC2001,SC2016
function es()       { sed -e 's/[]\.|$(){}?+*^[\&]/\\&/g' <<< "$1"; }
function pure()     { sed -re 's:^(refs/)?(heads/)?(tags/)?(remotes/)?(origin/)?(.*)$:\6:' <<< "$1"; }

function deleteRemote() {
  local name="${1:?name is required}"
  if [[ -n "${REMOTE_REF}" ]]; then
    # shellcheck disable=SC2015
    git push origin --delete "${name}" \
      && success "${REMOTE_REF}" "origin/${name}" "removed from remote ..." \
      || warn "failed to delete ${REMOTE_REF} origin/${name} ..."
  else
    warn "origin/${name}" "cannot be found in remote ..."
  fi
}

function deleteLocal() {
  local name="${1:?name is required}"
  if   [[ 1 = "${BRANCH_FOUND}" ]]; then git branch -D "${name}" && success "branch " "${name}" "removed from local ..."
  elif [[ 1 = "${TAG_FOUND}"    ]]; then git tag    -d "${name}" && success "tag    " "${name}" "removed from local ..."
  else warn "${name}" "cannot be found in local ..."
  fi
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    -r | --remote ) MODE='remote' ; shift    ;;
    -l | --local  ) MODE='local'  ; shift    ;;
    -h | --help   ) showHelp                 ;;
    --            ) shift                    ;;
    -*            ) die "unknown option: $1" ;;
    *             ) if [[ -n "${refname:-}" ]]; then
                      die "unexpected extra argument: $(c Mi)${1}$(c)" >&2
                    fi
                    refname="$1"  ; shift    ;;
  esac
done

git rev-parse --is-inside-work-tree >/dev/null 2>&1 || { echo "fatal: not a git repository" >&2; exit 128; }
declare -r CURRENT_BRANCH="$(es "$(git rev-parse --abbrev-ref HEAD 2>/dev/null)")"
git remote | grep --color=never -q . && git fetch --tags --prune --prune-tags --quiet

# build refs based on the MODE
declare -a refs=()
case "${MODE}" in
  remote ) refs=( refs/remotes )            ;;
  local  ) refs=( refs/heads )              ;;
  both   ) refs=( refs/heads refs/remotes ) ;;
esac

declare BRANCHES="$( git for-each-ref "${refs[@]}" --sort=-committerdate --format='%(refname:short)' )"
declare TAGS=$(git for-each-ref refs/tags --sort=-committerdate --format='%(refname:lstrip=1)')

function getRefname() {
  local showPager=$(git config pager.show)
  local gpreview="git show --color=always --date=local -m {-1} ${showPager:+| ${showPager} --color=always} | less -+F -R"
  local -x gpreviewS="git show --color=always --date=local -s {1} ${showPager:+| ${showPager} --color=always}"
  local -x plogs="git --no-pager log --decorate --color --graph --abbrev-commit --date=relative --pretty=tformat:'%C(#678963)%h%C(reset) %C(dim white)-%C(reset)%C(auto)%d%C(reset) %s %C(green)(%cr) %C(italic blue)<%an>%C(reset)' {1}"

  # shellcheck disable=SC2016
  rname=$( { echo "${BRANCHES}"; echo "${TAGS}"; } | fmt -1 |
             grep --color=never -vE "^[[:space:]]*$|origin$|^(origin/)?${CURRENT_BRANCH}$" |
             fzf --exit-0 --no-multi --prompt=' ' \
                 --preview "${plogs}" --preview-label='[ log ]' \
                 --height 50% --min-height 10+ \
                 --style full --no-border --no-input-border \
                 --preview-window=right,65%,nofollow --preview-label-pos='bottom' \
                 --footer='Ctrl-O: view commit / Alt-j: open jira / Ctrl-/: change preview' \
                 --bind "ctrl-o:execute(${gpreview})+change-preview(${gpreviewS})+change-prompt( )" \
                 --bind 'alt-j:execute-silent(
                           id=$(echo {} | grep -oE "([a-zA-Z]+-[0-9]+)" | head -n1 | tr "[:lower:]" "[:upper:]")
                           if [[ -n "${id}" ]]; then open "${JIRA_URL:-https://jira.domain.com}/browse/${id}"; fi
                         )' \
                 --bind 'ctrl-\:transform:[[ $FZF_PREVIEW_LABEL == *log* ]] \
                           && echo "change-preview[${gpreviewS}]+change-preview-label([ show ])" \
                           || echo "change-preview[${plogs}]+change-preview-label([ log ])"
                        ' \
                 --bind 'click-footer:transform:[[ $FZF_CLICK_FOOTER_WORD =~ Ctrl ]] && echo "trigger(${FZF_CLICK_FOOTER_WORD%:})"' \
                 --bind 'ctrl-]:change-preview-window:up,60%|hidden|right,65%' |
             sed -rn "s:\s*(origin/)?(.*)$:\2:p"
         );
  [[ -n "${rname}" ]] && echo "${rname}" || exit 1
}


if [[ -n "${refname:-}" ]]; then
  # normalize user-supplied refname: refs/remotes/origin/foo, refs/heads/foo, origin/foo, refs/tags/v1 → bare name
  refname="$(pure "${refname}")"
  refname=$({ echo "${BRANCHES}"; echo "${TAGS}"; } | fmt -1 |
              grep --color=never -vE "^[[:space:]]*$|origin$|^(origin/)?${CURRENT_BRANCH}$" |
              grep --color=never -E "$(es "${refname}")$" |
              sed -rn "s:\s*(origin/)?(.*)$:\2:p" |
              uniq
           )
else
  refname="$(getRefname)"
fi

[[ -z "${refname}" ]] && exit;
declare name="$(pure "${refname}")"

# check remote ref type
echo "${BRANCHES}"    | grep --color=never -qE "^origin/$(es "${name}")$" && REMOTE_REF='branch'
echo "${TAGS}"        | grep --color=never -qE "^tags/$(es "${name}")$"   && REMOTE_REF='tag'

# check local ref status
echo "${BRANCHES}"    | grep --color=never -qE "^$(es "${name}")$"        && BRANCH_FOUND=1
git --no-pager tag -l | grep --color=never -qxF "${name}"                 && TAG_FOUND=1

test 'local'  != "${MODE}" && deleteRemote "${name}"
test 'remote' != "${MODE}" && deleteLocal  "${name}"

# vim:tabstop=2:softtabstop=2:shiftwidth=2:expandtab:filetype=sh:
