#!/usr/bin/env bash
# shellcheck source=/dev/null disable=SC2155
#=============================================================================
#     FileName : git-rr
#       Author : marslo
#      Created : 2023-01-12 20:36:04
#   LastChange : 2026-03-07 02:31:41
#=============================================================================

shopt -s extglob

declare -r ME="$(basename "${BASH_SOURCE[0]:-$0}" | sed 's/-/ /g')"
declare -r HERE="$( dirname "${BASH_SOURCE[0]:-$0}" )"
# @credit: https://github.com/ppo/bash-colors
# @usage:  or copy & paste the `c()` function from:
#          https://github.com/ppo/bash-colors/blob/master/bash-colors.sh#L3
# shellcheck disable=SC2015
test -f "${HERE}/bash-colors.sh" && source "${HERE}/bash-colors.sh" || { c() { :; }; }

function die() { echo -e "$(c Rs)ERROR$(c) : $*" >&2; exit 2; }
function exitOnError() { if [ $? -ne 0 ]; then echo -e "$(c Rs)ERROR$(c) : $*" >&2; exit 1; fi; }
function showHelp() { echo -e "${USAGE}"; exit 0; }
function needsArg() { [[ -z "$OPTARG" ]] && die "no arg for --$OPT option"; }
function isRepo() { git rev-parse --git-dir >/dev/null 2>&1 || exitOnError 'not a git repo !'; }
function getRevision() { git rev-parse -q --verify "$1^{commit}"; }
function trim() { IFS='' read -r str; echo "${str}" | sed -e 's/^[[:blank:]]*//;s/[[:blank:]]*$//'; }

function showParams() {
  [[ 6 -ne $# ]] && die "wrong parameters in showParams function"
  local author=$1
  local authorEmail=$2
  local authorDate=$3
  local committer=$4
  local commitEmail=$5
  local commitDate=$6

  echo -e """
       $(c M)author$(c) : '${author}'
  $(c M)authorEmail$(c) : '${authorEmail}'
   $(c M)authorDate$(c) : '${authorDate}'
    $(c M)committer$(c) : '${committer}'
  $(c M)commitEmail$(c) : '${commitEmail}'
   $(c M)commitDate$(c) : '${commitDate}'
       $(c M)params$(c) : $(c G)
                 ${ME} -a '${author}' -e '${authorEmail}' -d '${authorDate}' -c '${committer}' -E '${commitEmail}' -D '${commitDate}'
                 ${ME} --author=\"${author}\" --authorEmail=\"${authorEmail}\" --authorDate=\"${authorDate}\" --committer=\"${committer}\" --commitEmail=\"${commitEmail}\" --commitDate=\"${commitDate}\"$(c)
  $(c M)environment$(c) : $(c C)
                 export GIT_AUTHOR_NAME='${author}'
                 export GIT_AUTHOR_EMAIL='${authorEmail}'
                 export GIT_AUTHOR_DATE='${authorDate}'
                 export GIT_COMMITTER_NAME='${committer}'
                 export GIT_COMMITTER_EMAIL='${commitEmail}'
                 export GIT_COMMITTER_DATE='${commitDate}'$(c)
  """
}

function getInfo() {
  [[ 1 -ne $# ]] && die "must provide the revision number or refspec name for function getInfo"
  local revision=$1
  local command="git show -s ${revision} --pretty=tformat:'%an | %ae | %ad | %cn | %ce | %cd'"
  echo -n "$(eval "${command}" || exitOnError 'failed to get revision information')"
}

function setEnv() {
  [[ 6 -ne $# ]] && die "wrong parameters in showParams function"
  local author=$1
  local authorEmail=$2
  local authorDate=$3
  local committer=$4
  local commitEmail=$5
  local commitDate=$6

  export GIT_AUTHOR_NAME="${author}"
  export GIT_AUTHOR_EMAIL="${authorEmail}"
  export GIT_AUTHOR_DATE="${authorDate}"
  export GIT_COMMITTER_NAME="${committer}"
  export GIT_COMMITTER_EMAIL="${commitEmail}"
  export GIT_COMMITTER_DATE="${commitDate}"

  echo -e """
  .. environment variable has been set to ..
  $(c C)
    GIT_AUTHOR_NAME='${author}'
    GIT_AUTHOR_EMAIL='${authorEmail}'
    GIT_AUTHOR_DATE='${authorDate}'
    GIT_COMMITTER_NAME='${committer}'
    GIT_COMMITTER_EMAIL='${commitEmail}'
    GIT_COMMITTER_DATE='${commitDate}'
  $(c)

  .. or you can manual export again ..
    $(c C)\$ export GIT_AUTHOR_NAME='${author}'; export GIT_AUTHOR_EMAIL='${authorEmail}'; export GIT_AUTHOR_DATE='${authorDate}'; export GIT_COMMITTER_NAME='${committer}'; export GIT_COMMITTER_EMAIL='${commitEmail}'; export GIT_COMMITTER_DATE='${commitDate}'$(c)
  """
}

function unsetEnv() {
  GIT_COMMIT_ENV="GIT_AUTHOR_NAME GIT_AUTHOR_EMAIL GIT_AUTHOR_DATE GIT_COMMITTER_NAME GIT_COMMITTER_EMAIL GIT_COMMITTER_DATE";
  for envvar in ${GIT_COMMIT_ENV}; do unset "${envvar}"; done;
  echo -e """
    .. unset successfully ..\n
      $(echo "${GIT_COMMIT_ENV}" | trim | tr ' ' ',') has been removed.

    .. or you can manually unset environment variable again ..\n
      $(c C)\$ unset GIT_AUTHOR_NAME; unset GIT_AUTHOR_EMAIL; unset GIT_AUTHOR_DATE; unset GIT_COMMITTER_NAME; unset GIT_COMMITTER_EMAIL; unset GIT_COMMITTER_DATE$(c)
  """;
  exit 0
}

# call git-mi
function doModify() {
  [[ 6 -ne $# ]] && die "wrong parameters in doModify function"
  local author=$1
  local authorEmail=$2
  local authorDate=$3
  local committer=$4
  local commitEmail=$5
  local commitDate=$6
  local -a cmd=( bash "${HERE}/git-mi" --author="${author}" --authorEmail="${authorEmail}" --authorDate="${authorDate}" --committer="${committer}" --commitEmail="${commitEmail}" --commitDate="${commitDate}" )
  "${cmd[@]}" || exitOnError 'failed to modify revision information (via git-mi)'
}

declare SHOW_DEFAULT=false
declare VERBOSE=false
declare CHERRY_PICK=false
declare SETENV=false
declare sha=''
# shellcheck disable=SC2155
declare -r USAGE="NAME
  $(c Ys)${ME}$(c) - $(c Ys)r$(c)evision $(c Ys)r$(c)eset - to reset the git revision author/authorEmail/authorDates/committer/commitEmail/commitDate

SYNOPSIS
  $(c Ys)\$ ${ME} $(c 0G)[options] $(c 0Mi)<sha1|refspec>$(c)

OPTIONS
  $(c G)-s$(c), $(c G)--set$(c)                reset revision information and setup the commit/push environment
  $(c G)-u$(c), $(c G)--unset$(c)              remove all git commit environment variables
  $(c G)-c$(c), $(c G)--cp$(c), $(c G)--cherry-pick$(c)  cherry-pick the revision to current branch
  $(c G)-r$(c), $(c G)--revision$(c 0Cs)=$(c 0Mi)<sha1>$(c)    reset revision information to the specified revision
  $(c G)-d$(c), $(c G)--default$(c)            set the author/committer to default ( from git config )
  $(c G)-v$(c), $(c G)--verbose$(c), $(c G)--debug$(c)   get verbose revision information
  $(c G)-h$(c)                       show this help message and exit

EXAMPLE
  $(c Wdi)# show verbose$(c)
  $(c Y)\$ ${ME} $(c 0Gi)-v$(c 0Wd) | $(c 0Y)\$ ${ME} $(c 0Gi)--verbose$(c 0Wd) | $(c 0Y)\$ ${ME} $(c 0Gi)--debug$(c)
  $(c Wdi)# to set the author/committer to default ( from git config )$(c)
  $(c Y)\$ ${ME} $(c 0Gi)-d --revision$(c 0Cs)=$(c 0Mi)<revision>$(c 0Wd) | $(c 0Y)\$ ${ME} $(c 0Gi)-d -r $(c 0Mi)<revision>$(c)
  $(c Wdi)# to cherry-pick and reset revision information$(c)
  $(c Y)\$ ${ME} $(c 0Gi)-c --revision$(c 0Cs)=$(c 0Mi)<revision>$(c 0Wd) | $(c 0Y)\$ ${ME} $(c 0Gi)-c -r $(c 0Mi)<revision>$(c)
                        $(c Wi)+ the long parameters MUST use $(c 0Cs)'='$(c 0Wi) to identify opt and args$(c)
  $(c Wdi)# to reset revision information only$(c)
  $(c Y)\$ ${ME} $(c 0Gi)--revision$(c 0Cs)=$(c 0Mi)<revision>$(c 0Wd) | $(c 0Y)\$ ${ME} $(c 0Gi)-r $(c 0Mi)<revision>$(c)
                     $(c Wi)+ the long parameters MUST use $(c 0Cs)'='$(c 0Wi) to identify opt and args$(c)
  $(c Wdi)# to reset revision information and setup the commit/push environment$(c)
  $(c Y)\$ ${ME} $(c 0Gi)--set --revision$(c 0Cs)=$(c 0Mi)<revision>$(c 0Wd) | $(c 0Y)\$ ${ME} $(c 0Gi)-s -r $(c 0Mi)<revision>$(c)
  $(c Wdi)# to remove all git commit environment variables$(c)
  $(c Y)\$ ${ME} $(c 0Gi)-u$(c 0Wd) | $(c 0Y)${ME} $(c 0Gi)--unset$(c)
"

# for non '-' params
if [[ 0 -eq $# ]]; then
  showHelp
# simple usage: not starts with '-' && not contains '='
elif [[ 1 -eq $# ]] && [[ '-' != "${1::1}" ]] && [[ "$1" =~ '=' ]]; then
  sha="$1"
# for '-'/'--' params
else
  # @credit: https://stackoverflow.com/a/28466267/519360
  # shellcheck disable=SC2295
  while getopts :hdsvcr:-: OPT; do
    if [ "$OPT" = "-" ]; then
      OPT="${OPTARG%%=*}"
      OPTARG="${OPTARG#$OPT}"
      OPTARG="${OPTARG#=}"
    fi
    case "$OPT" in
      h                    ) showHelp                    ;;
      d | default          ) SHOW_DEFAULT=true           ;;
      v | verbose | debug  ) VERBOSE=true                ;;
      c | cp | cherry-pick ) CHERRY_PICK=true            ;;
      s | set              ) SETENV=true                 ;;
      u | unset            ) unsetEnv                    ;;
      r | revision         ) needsArg; sha="$OPTARG"     ;;
      ??*                  ) die "Illegal option --$OPT" ;;
      ?                    ) die "Illegal option --$OPT" ;;
    esac
  done
  [[ 1 -eq $OPTIND ]] && showHelp
  shift $((OPTIND-1))
fi

isRepo
declare revision=$( getRevision "${sha}" )
[[ -z "${revision}" ]] && die "ref '${sha}' cannot be found in current repo."
declare shortRevision="${revision:0:10}"

declare values=$( getInfo "${revision}" )
declare authorDate=$( echo "${values}"  | awk -F'|' '{print $3}' | trim )
declare commitDate=$( echo "${values}"  | awk -F'|' '{print $6}' | trim )

declare author='' authorEmail='' committer='' commitEmail=''
if "${SHOW_DEFAULT}"; then
  declare _name='' _email=''
  _name=$( git config user.name )
  _email=$( git config user.email )
  author="${_name}"
  authorEmail="${_email}"
  committer="${_name}"
  commitEmail="${_email}"
else
  author=$( echo "${values}"      | awk -F'|' '{print $1}' | trim )
  authorEmail=$( echo "${values}" | awk -F'|' '{print $2}' | trim )
  committer=$( echo "${values}"   | awk -F'|' '{print $4}' | trim )
  commitEmail=$( echo "${values}" | awk -F'|' '{print $5}' | trim )
fi

"${VERBOSE}"     && showParams "${author}" "${authorEmail}" "${authorDate}" "${committer}" "${commitEmail}" "${commitDate}"
"${CHERRY_PICK}" && git cherry-pick "${revision}"
"${SETENV}"      && setEnv "${author}" "${authorEmail}" "${authorDate}" "${committer}" "${commitEmail}" "${commitDate}"
doModify "${author}" "${authorEmail}" "${authorDate}" "${committer}" "${commitEmail}" "${commitDate}"

if [[ -n "${revision}" ]]; then
  echo -e """
    .. FINAL RESULT .. \n
    $(c Y)${shortRevision}$(c) : ${values}
    \t  $(c Y)HEAD$(c) : $(getInfo HEAD)
  """
fi

# vim:tabstop=2:softtabstop=2:shiftwidth=2:expandtab:filetype=sh:
