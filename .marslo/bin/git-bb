#!/usr/bin/env bash
#=============================================================================
#     FileName : git-bb
#       Author : marslo.jiao@gmail.com
#      Created : 2023-12-11 21:39:58
#   LastChange : 2026-03-23 21:15:20
#  Description : git branch switcher
#                 - init : [a83a0ec](https://github.com/marslo/dotfiles/commit/a83a0ec625f154dc096750b777cb39108e50e5f9)
#                 - `ctrl-/` and `ctrl-o` to modify view and `ctrl-y` copy commit hash
#                 -  - E0A0/E725
#                 - `ctrl-k` to open the jira-id in browser ( if applicable )
#=============================================================================

set -euo pipefail

# isGHE && main="$(gh repo view --json defaultBranchRef -q .defaultBranchRef.name)"
function isGHE() {
  git remote get-url origin | grep -qE '(git@|https://).+[:/]Marvell-[^/]+/'
}

# shellcheck disable=SC2155,SC2016
function getBranch() {
  local current="$(git symbolic-ref -q HEAD)"
  local showPager=$(git config pager.show)
  local gpreview="git show --color=always --date=local {1} ${showPager:+| ${showPager} --color=always}"
  local gpreviewS="git show --color=always --date=local -s {1} ${showPager:+| ${showPager} --color=always}"

  # git remote set-head origin --auto
  local main
  test -f "$(git rev-parse --absolute-git-dir)"/refs/remotes/origin/HEAD &&
    main="$(git symbolic-ref -q refs/remotes/origin/HEAD 2>/dev/null)" ||
    main=''

  local branch=$({
                   [[ -n "${main:-}" && "${main#refs/remotes/origin/}" != "${current#refs/heads/}" ]] && echo "+ ${main} ${main#refs/remotes/}"
                   git for-each-ref refs/heads refs/remotes --sort=-committerdate --format="%(refname) %(refname:short)";
                 } |
                 awk -v cur="${current}" -v ALL="${SHOW_ALL:-false}" -v rc=$'\033[0;3m' -v lc=$'\033[0;36m' -v rst=$'\033[0m' '
                   $1 == "+" {
                     pin_full = $2; pin_short = $3
                     pin_base = substr( pin_short, 8 )
                     next
                   }

                   NF == 2 {
                     full = $1; short = $2
                     if ( short == "origin" || full ~ /\/HEAD$/ ) next
                     F[++n] = full; S[n] = short
                     if ( index(short, "origin/") != 1 ) local_exists[short] = 1
                   } END {
                     if ( pin_full ) {
                       if ( local_exists[pin_base] ) {
                         l_full = "refs/heads/" pin_base
                         printf "%s\t%s%s%s\n", l_full, lc, pin_base, rst
                         seen[l_full] = 1
                       }
                       if ( ALL == "true" || !local_exists[pin_base] ) {
                         printf "%s\t%s%s%s\n", pin_full, rc, pin_short, rst
                         seen[pin_full] = 1
                       }
                     }

                     for ( i = 1; i <= n; i++ ) {
                       full = F[i]; short = S[i]
                       if ( seen[full]++ || full == cur ) continue
                       is_remote = ( index(short, "origin/") == 1 )
                       if ( is_remote && ALL == "false" && local_exists[substr(short, 8)] ) continue
                       printf "%s\t%s%s%s\n", full, ( is_remote ? rc : lc ), short, rst
                     }
                   }
                 ' |
                 fzf --no-multi --ansi --prompt=' ' --exit-0 \
                     --layout=reverse \
                     --delimiter '\t' --with-nth 2 \
                     --height 50% --min-height 10+ \
                     --style full --no-input-border \
                     --preview "${gpreviewS}" \
                     --info='inline-right' \
                     --preview-window=right,55%,nofollow --preview-label-pos='bottom' \
                     --bind "ctrl-o:execute(${gpreview})+change-preview(${gpreviewS})+change-prompt( )" \
                     --bind 'ctrl-\:change-preview-window:up,60%|hidden|right,55%' \
                     --bind 'ctrl-y:execute-silent(git log {1} -1 --pretty=format:"%H" | pbcopy)' \
                     --bind 'ctrl-k:execute-silent(
                               id=$(echo {2} | grep -oE "([a-zA-Z]+-[0-9]+)" | head -n1 | tr "[:lower:]" "[:upper:]")
                               if [[ -n "${id}" ]]; then open "https://jira.domain.com/browse/${id}"; fi
                             )'
                )

  [[ -n "${branch}" ]] && echo "${branch}" || exit 1
}

git rev-parse --is-inside-work-tree >/dev/null 2>&1 || {
  echo "fatal: not a git repository (or any of the parent directories): .git" >&2;
  exit 128
}

declare FORCE=false
declare SHOW_ALL=false
declare branch=''

while [[ $# -gt 0 ]]; do
  case "$1" in
    -f | --force ) FORCE=true           ; shift ;;
    -a | --all   ) SHOW_ALL=true        ; shift ;;
    -*           ) echo "ERROR: unknown option '$1'" >&2; exit 1;;
    *            ) branch="$1"$'\t'"$1" ; shift ;;
  esac
done

# <full ref>\t<short ref>
if [[ -z "${branch:-}" ]]; then branch="$(getBranch)"; fi
# shellcheck disable=SC2155
if [[ -n "${branch:-}" ]]; then
  declare _short="$( awk -F'\t' '{print $2}' <<< "${branch}" )"
  declare _full="$( awk -F'\t' '{print $1}' <<< "${branch}" )"
  printf "\033[0;2;3;37m~~> %b\033[0;2;3;37mcheckout \033[0;1;33m%s\033[0m\n" \
         "$(${FORCE} && printf '\033[0;1;3;35mforce\033[0m ')" "${_full}"

  declare -a cmd=( git checkout "${_short}" )
  ${FORCE:-false} && cmd+=( --force ) || :
  "${cmd[@]}"
fi

# vim:tabstop=2:softtabstop=2:shiftwidth=2:expandtab:filetype=sh:
