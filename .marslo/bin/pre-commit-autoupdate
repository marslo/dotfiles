#!/usr/bin/env bash
#=============================================================================
#     FileName : pre-commit-autoupdate
#       Author : marslo
#      Created : 2026-05-13 14:15:00
#   LastChange : 2026-05-18 23:26:05
#  Description : `pre-commit autoupdate` — runs real autoupdate → fixes repos that use rolling major-version tags
#                e.g. crate-ci/typos publishes "v1"
#=============================================================================

set -euo pipefail

# shellcheck disable=SC2155
declare -r HERE="$( cd "$( dirname "${BASH_SOURCE[0]:-$0}" )" && pwd )"

function backer() {
  local _path
  _path=$(echo "${PATH}" | awk -v RS=: -v ORS=: -v skip="${HERE}" '$1 != skip' | sed 's/:$//')
  PATH="${_path}" command -v pre-commit || { echo >&2 "error: real pre-commit not found in PATH"; return 1; }
}

readonly CFG='.pre-commit-config.yaml'
readonly ROLLING_REPOS=('crate-ci/typos')
[[ ! -f "${CFG}" ]] && { echo >&2 "error: $CFG not found in $(pwd)"; exit 1; }
trap 'rm -f "${CFG}.bak"' EXIT

: "${_REAL_PRECOMMIT:=$(backer)}"
"${_REAL_PRECOMMIT}" autoupdate "$@"

for repo in "${ROLLING_REPOS[@]}"; do
  if ! grep -q "${repo}" "${CFG}"; then continue; fi

  latest=$(
    curl -fsSL ${GITHUB_TOKEN:+-H "Authorization: token $GITHUB_TOKEN"} \
      "https://api.github.com/repos/${repo}/releases/latest" |
      jq -r '.tag_name // empty'
  ) || true
  [[ -z "${latest}" ]] && { echo >&2 "warning: could not fetch latest release for ${repo}, skipping"; continue; }

  escaped="${repo//\//\\/}"
  current=$(sed -n "/${escaped}/{n;s/.*rev:[[:space:]]*//p;}" "${CFG}" | head -1)

  if [[ "${current}" != "${latest}" ]]; then
    sed -i.bak "/${escaped}/{n;s/rev:.*/rev: ${latest}/;}" "${CFG}"
    printf "\033[0;2;3;37m[https://github.com/%s]\033[0m \033[0;1;36mfixed rev\033[0m: \033[0;1;3;34m%s\033[0m -> \033[0;1;3;35m%s\033[0m\n" "${repo}" "${current}" "${latest}"
  fi
done

# vim:tabstop=2:softtabstop=2:shiftwidth=2:expandtab:filetype=sh:
