#!/usr/bin/env bash
# shellcheck source=/dev/null disable=SC2155

# NAME   : now
# PATH   : $HOME/bin
# DESC   : Display current weather, calendar and time
# CALL   : Called from terminal or ~/.bashrc
# DATE   : Apr 6, 2017. Modified: May 24, 2019.
# CREDIT : https://askubuntu.com/a/1020693/92979

# UPDT   : 2019-05-24 If Weather unavailable nicely formatted error message.
# UPDT   : 2024-01-26 fix the "today" position offset issue due to extra space in `cal`
# UPDT   : 2026-04-01 add lolcat for color time output (if available); add dynamic column position base on width of weather
# UPDT   : 2026-04-01 refactor the whole structure, and using dynamic MAX_LINES for prompt location

# NOTE   : to display all available toilet fonts use this one-liner:
#          for i in ${TOILET_FONT_PATH:=/usr/share/figlet}/*.{t,f}lf; do j=${i##*/}; toilet -d "${i%/*}" -f "$j" "${j%.*}"; done

# get width of calendar dynamically via `$(tput cols)`
declare DATE_COLUMN=38                                   # default is 27 for 80 character line, 34 for 92 character line
declare TIME_COLUMN=$(( DATE_COLUMN + 24 ))
declare intranet=$(netstat -nr -f inet | awk '$3 ~ /UGScg|UG/' | awk '$2 ~ /10\.(85|86|87|68|78)\.[0-9]{1,3}\.[0-9]{1,3}/' | wc -l)
declare temp=$(mktemp -d)
declare -a CURL=( curl '-sgk' --fail --silent --max-time 3 )
#              timeout #. increase for slow connection---^
[[ "${intranet}" -gt 0 ]] && CURL+=( -x "${PROXY_URL:-http://proxy.domain.com:8080}" )

function updateMaxLines() {
  local file="${1:?File path is required}"
  local offset="${2:-0}"
  local lines=0

  if [[ -f "${file}" ]]; then
    lines=$(wc -l < "${file}")
    [[ $(( lines + offset )) -gt ${MAX_LINES} ]] && MAX_LINES=$(( lines + offset ))
  fi
}

# --- ${temp}/now-weather ---
if ! "${CURL[@]}" wttr.in/sanjose?QmM0 1>"${temp}"/now-weather 2>/dev/null; then
  ~/.marslo/bin/iweather > "${temp}"/now-weather
fi
if ! grep -q '°C' "${temp}/now-weather" 2>/dev/null; then
  test -f "${temp}/now-weather" && rm -f "${temp}/now-weather"
fi

# --- ${temp}/now-calendar ---
# -h needed to turn off formatting: https://askubuntu.com/questions/1013954/bash-substring-stringoffsetlength-error/1013960#1013960
# -h not supported in Ubuntu 18.04. Use second answer: https://askubuntu.com/a/1028566/307523
# to fit for both macOS and Linux
#   - linux: cal have 2 more extra whitespace in each line, 22 chars per line
#   - osx: cal has no more extra whitespace in each line, 20 chars per line
#                    cal -h                 remove trailing spaces     remove empty line
#                       v                              v                       v
cal | tr -cd '\11\12\15\40\60-\136\140-\176' | sed 's/[ \t]*$//' | sed '/^[[:space:]]*$/d' > "${temp}"/now-calendar

# --- ${temp}/now-time ---
declare -a charCmd=()
if hash toilet 2>/dev/null; then
  charCmd=( toilet -f future )
elif hash figlet 2>/dev/null; then
  declare _ffont=''
  test 'Darwin' = "$(uname)"                   && _ffont="$(brew --prefix)"/share/figlet/future.tlf
  test -f '/usr/local/share/figlet/future.tlf' && _ffont='/usr/local/share/figlet/future.tlf'
  test -f '/usr/share/figlet/future.tlf'       && _ffont='/usr/share/figlet/future.tlf'
  charCmd=( figlet -f "${_ffont}" )
fi
# shellcheck disable=SC2015
[[ ${#charCmd[@]} -gt 0 ]] && date +"%I:%M %P" | "${charCmd[@]}" > "${temp}"/now-time \
                           || date +"%I:%M %P" > "${temp}"/now-time
hash lolcat 2>/dev/null && lolcat -f --freq=0.2 --spread=2.0 "${temp}"/now-time > "${temp}"/now-time.tmp && mv "${temp}"/now-time.tmp "${temp}"/now-time

#------------------------------ MAX_LINES ------------------------------
declare MAX_LINES=0
updateMaxLines "${temp}/now-calendar"
updateMaxLines "${temp}/now-weather" 1
updateMaxLines "${temp}/now-time"    1
printf '\n%.0s' $(seq 1 ${MAX_LINES})
tput cuu ${MAX_LINES}
tput sc

#------------------------------ WEATHER ------------------------------
if [[ -f "${temp}/now-weather" ]]; then
  tput rc && tput cud1                            # back to anchor and move down 1 line
  cat "${temp}/now-weather"
  _width=$(sed 's/\x1b\[[0-9;]*m//g' "${temp}/now-weather" | wc -L)
  DATE_COLUMN=$(( _width + 3 ))
else
  DATE_COLUMN=1
fi
TIME_COLUMN=$(( DATE_COLUMN + 24 ))

#------------------------------ CALENDAR ------------------------------
tput rc && tput cuf ${DATE_COLUMN}                 # back to anchor and move right ${DATE_COLUMN} column

calLineCnt=1
today=$(date +"%e")
printf "\033[32m"

while IFS= read -r cal; do
  printf "%s" "${cal}"
  if [[ ${calLineCnt} -gt 2 ]] ; then
    tput cub "$(awk '{print length($0)}' <<< "${cal}")"
    for (( j=0 ; j <= 18 ; j += 3 )) ; do
      day=${cal:$j:2}
      if [[ "${day}" == "${today}" ]] ; then
        printf "\033[7m%s\033[27m" "${today}"
        tput cuf 1
      else
        tput cuf 3
      fi
    done
  fi

  tput cud1
  tput cuf ${DATE_COLUMN}
  calLineCnt=$(( ++calLineCnt ))
done < "${temp}"/now-calendar
printf '\033[00m'

#------------------------------ TIME ------------------------------
tput rc && tput cud1                              # back to anchor and move down 1 line
tput cuf ${TIME_COLUMN}                            # move right ${TIME_COLUMN} column

while IFS= read -r timeStr; do
  hash toilet 2>/dev/null || printf "\033[01;35m"
  printf "%b" "${timeStr}"
  tput cud1
  tput cuf ${TIME_COLUMN}
done < "${temp}"/now-time
printf "\033[00m"

tput rc && tput cud ${MAX_LINES}                  # back to anchor and move down ${MAX_LINES} lines

test -d "${temp}" && rm -rf "${temp}"
exit 0

# vim:tabstop=2:softtabstop=2:shiftwidth=2:expandtab:filetype=sh:foldmethod=indent:
