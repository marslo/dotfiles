#!/usr/bin/env bash
# shellcheck source=/dev/null
#=============================================================================
#     FileName : jira
#       Author : marslo
#      Created : 2026-03-09 16:23:03
#   LastChange : 2026-03-12 17:06:47
#=============================================================================

set -euo pipefail

# shellcheck disable=SC2155
declare -r ME="$( basename "${BASH_SOURCE[0]:-$0}" )"
# shellcheck disable=SC2155
declare -r HERE="$( dirname "${BASH_SOURCE[0]:-$0}" )"
# @credit: https://github.com/ppo/bash-colors
# @usage:  or copy & paste the `c()` function from:
#          https://github.com/ppo/bash-colors/blob/master/bash-colors.sh#L3
# shellcheck disable=SC2015
test -f "${HERE}/bash-colors.sh" && source "${HERE}/bash-colors.sh" || { c() { :; }; }

# shellcheck disable=SC2155
declare -r USAGE="NAME
  $(c 0Ys)${ME}$(c) - A CLI tool for Jira

USAGE
  $(c 0Ys)\$ ${ME}$(c) $(c 0Cs)<subcommand> $(c 0Gs)[options]$(c)

SUBCOMMANDS
  $(c C)ls$(c)          List jira issues
  $(c C)stat$(c)        Show statistics

OPTIONS
  $(c G)-h$(c), $(c G)--help$(c)  Show this help message and exit

Run '${ME} help <command>' or '${ME} <command> --help' for details.
"

function showUsage() { echo -e "${USAGE}"; exit 0; }
function die() { echo -e "$(c Ri)ERROR$(c)$(c i): $*.$(c) $(c Wdi)exit ...$(c)" >&2; exit 1; }

# shellcheck disable=SC2015
if [[ "$1" == "help" ]]; then
  [[ -n "${2:-}" ]] && set -- "${2}" "--help" || showUsage
fi

declare SUBCOMMAND="$1"; shift;
case "${SUBCOMMAND}" in
  ls | --ls | stat | --stat ) COMMAND="${SUBCOMMAND#--}"; SCRIPT_PATH="${HERE}/jira-${COMMAND}"
                              if [[ -f "${SCRIPT_PATH}" ]]; then
                                exec bash "${SCRIPT_PATH}" "$@"
                              else
                                die "Subcommand script 'jira-${COMMAND}' not found at ${HERE}"
                              fi ;;
  -h | --help | ''          ) showUsage                                ;;
  -*                        ) die "unknown option '${SUBCOMMAND}'"     ;;
  *                         ) die "unknown subcommand '${SUBCOMMAND}'" ;;
esac

# vim:tabstop=2:softtabstop=2:shiftwidth=2:expandtab:filetype=sh:
