#!/usr/bin/env bash
# shellcheck source=/dev/null
#=============================================================================
#     FileName : .alias
#       Author : marslo.jiao@gmail.com
#      Created : 2025-02-12 14:45:55
#   LastChange : 2025-06-27 17:27:25
#=============================================================================

# shellcheck disable=SC2154
declare ALIAS_HOME="${iRCHOME}/alias.d"

while read -r _i; do
  source "${ALIAS_HOME}/${_i}"
done < <(/bin/ls -1 "${ALIAS_HOME}" | grep --color=never -vE "docker|kubernetes|mac")

[[ 'Darwin' = "$(uname --operating-system)" ]] && source "${ALIAS_HOME}"/mac
type -P kubectl >/dev/null 2>&1                && source "${ALIAS_HOME}"/kubernetes
type -P docker  >/dev/null 2>&1                && source "${ALIAS_HOME}"/docker

unset "${_i}"

# vim:tabstop=2:softtabstop=2:shiftwidth=2:expandtab:filetype=sh
